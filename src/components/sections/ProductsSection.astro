---
import { SITE } from "../../data/site";
import { SCHUCO_PROFILES, PRODUCT_CATEGORIES } from "../../data/products";
import Section from "../ui/Section.astro";
import Grid from "../ui/Grid.astro";
import Card from "../ui/Card.astro";
import Tag from "../ui/Tag.astro";
import Icon from "../ui/Icon.astro";
import IKImage from "../ui/IKImage.astro";
---

<Section
    id="producten"
    tag="Onze Producten"
    title="Kunststof kozijnen, deuren & schuifpuien"
    subtitle="Wij leveren een compleet assortiment kunststof gevelelementen van het merk Schüco — van kozijnen en deuren tot schuifpuien en sierpanelen."
>
    <Grid cols="auto" gap="lg" stagger class="products-grid">
        {
            PRODUCT_CATEGORIES.map((cat) => (
                <Card center variant="feature">
                    <div class="icon-box icon-box--xl product-icon">
                        <Icon name={cat.icon} size={32} strokeWidth={1.5} />
                    </div>
                    <h3 class="card-title product-title">{cat.name}</h3>
                    <p class="card-desc">{cat.description}</p>
                </Card>
            ))
        }
    </Grid>

    <!-- Schüco Profiles -->
    <div class="schuco-section">
        <div class="section-header schuco-header">
            <span class="section-tag">{SITE.schuco.tagline}</span>
            <h3 class="schuco-title">{SITE.schuco.title}</h3>
            <p class="section-subtitle">{SITE.schuco.description}</p>
        </div>

        <Grid cols={3} gap="lg">
            {
                SCHUCO_PROFILES.map((profile) => (
                    <Card bottomBar>
                        {profile.image ? (
                            <IKImage
                                src={profile.image}
                                alt={profile.imageAlt ?? profile.name}
                                aspectRatio="16/9"
                                widths={[400, 700, 960]}
                                sizes="(max-width: 768px) 100vw, 33vw"
                                quality={85}
                                focus="auto"
                                class="profile-img"
                            />
                        ) : (
                            <div class="profile-img-placeholder">
                                <svg class="profile-img-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                                    <polyline points="3 9 9 9 9 3"/>
                                    <polyline points="21 9 15 9 15 3"/>
                                    <polyline points="3 15 9 15 9 21"/>
                                    <polyline points="21 15 15 15 15 21"/>
                                </svg>
                            </div>
                        )}
                        <div class="profile-header">
                            <Tag variant="cta">{profile.subtitle}</Tag>
                            <h4 class="profile-name">{profile.name}</h4>
                        </div>
                        <p class="card-desc profile-desc">
                            {profile.description}
                        </p>
                        <p class="profile-best-for">
                            <strong>Ideaal voor:</strong> {profile.bestFor}
                        </p>
                        <ul class="feature-list">
                            {profile.features.map((f) => (
                                <li class="feature-item">
                                    <Icon
                                        name="check"
                                        size={14}
                                        strokeWidth={3}
                                    />
                                    {f}
                                </li>
                            ))}
                        </ul>
                    </Card>
                ))
            }
        </Grid>

        <!-- Vergelijkingstabel — GEO: AI engines citeren tabellen -->
        <div class="compare-wrapper">
            <h4 class="compare-title">Profielvergelijking</h4>
            <p class="compare-subtitle">Welk Schüco profiel past bij uw situatie?</p>
            <div class="compare-scroll">
                <table class="compare-table">
                    <thead>
                        <tr>
                            <th>Eigenschap</th>
                            <th>Schüco Living</th>
                            <th>CT70 Accent</th>
                            <th>Corona CT70</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Segment</td>
                            <td><strong>Premium</strong></td>
                            <td>Klassiek</td>
                            <td>Veelzijdig</td>
                        </tr>
                        <tr>
                            <td>Isolatiewaarde</td>
                            <td>Hoogste</td>
                            <td>Goed</td>
                            <td>Goed</td>
                        </tr>
                        <tr>
                            <td>Ideaal voor</td>
                            <td>Nieuwbouw</td>
                            <td>Renovatie</td>
                            <td>Nieuwbouw & renovatie</td>
                        </tr>
                        <tr>
                            <td>Design</td>
                            <td>Modern & strak</td>
                            <td>Klassiek</td>
                            <td>Tijdloos</td>
                        </tr>
                        <tr>
                            <td>Duurzaamheid</td>
                            <td>Uiterst duurzaam</td>
                            <td>Duurzaam</td>
                            <td>Zeer duurzaam</td>
                        </tr>
                        <tr>
                            <td>Prijs-kwaliteit</td>
                            <td>Premium</td>
                            <td>Uitstekend</td>
                            <td>Goed</td>
                        </tr>
                        <tr>
                            <td>ISDE-subsidie</td>
                            <td>Ja</td>
                            <td>Ja</td>
                            <td>Ja</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</Section>

<style>
    .product-icon {
        margin: 0 auto 1.25rem;
    }
    .product-title {
        font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
    }

    /* ─── Schüco profiel image placeholder ─────────────── */
    .profile-img-placeholder {
        aspect-ratio: 16 / 9;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(
            135deg,
            rgba(var(--color-cta-rgb), 0.07),
            rgba(var(--color-accent-rgb), 0.04)
        );
        border: 1px dashed rgba(var(--color-cta-rgb), 0.2);
        border-radius: var(--radius-md);
        margin: -1.25rem -1.25rem 1.25rem;
        border-top-left-radius: var(--radius-md);
        border-top-right-radius: var(--radius-md);
    }
    .profile-img-icon {
        color: var(--color-cta);
        opacity: 0.2;
    }

    /* IKImage — bleedt naar kaart-randen, zelfde als placeholder */
    :global(.profile-img) {
        margin: -1.25rem -1.25rem 1.25rem;
        border-top-left-radius: var(--radius-md);
        border-top-right-radius: var(--radius-md);
    }
    :global(.profile-img img) {
        border-top-left-radius: var(--radius-md);
        border-top-right-radius: var(--radius-md);
    }

    .schuco-section {
        margin-top: clamp(2.5rem, 6vw, 5rem);
        padding-top: 2rem;
        border-top: 1px solid var(--border-subtle);
    }
    .schuco-header {
        margin: 2.5rem auto 3rem;
    }
    .schuco-title {
        font-size: clamp(1.5rem, 3vw, 2rem);
        margin-bottom: 0.75rem;
    }

    .profile-header {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.625rem;
        margin-bottom: 1rem;
    }
    .profile-name {
        font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    }
    .profile-desc {
        margin-bottom: 0.875rem;
    }
    .profile-best-for {
        font-size: clamp(0.8125rem, 1.2vw, 0.875rem);
        color: var(--text-muted);
        margin-bottom: 1.125rem;
        padding: 0.5rem 0.875rem;
        background: rgba(var(--color-cta-rgb), 0.04);
        border-radius: var(--radius-sm);
        border-left: 3px solid var(--color-cta);
    }
    .profile-best-for strong {
        color: var(--text-primary);
    }

    /* ─── Comparison Table ────────────────────────────────── */

    .compare-wrapper {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-subtle);
        text-align: center;
    }

    .compare-title {
        font-family: var(--font-heading);
        font-size: clamp(1.125rem, 2.5vw, 1.375rem);
        font-weight: 700;
        color: var(--text-heading);
        margin-bottom: 0.375rem;
    }

    .compare-subtitle {
        font-size: 0.9375rem;
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
    }

    .compare-scroll {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border-radius: var(--radius-md);
        border: 1px solid var(--border-subtle);
    }

    .compare-table {
        width: 100%;
        min-width: 520px;
        border-collapse: collapse;
        font-size: 0.9375rem;
        text-align: left;
    }

    .compare-table th {
        background: rgba(var(--color-cta-rgb), 0.08);
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: 0.8125rem;
        color: var(--color-cta);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 0.875rem 1rem;
        border-bottom: 2px solid rgba(var(--color-cta-rgb), 0.15);
        white-space: nowrap;
    }

    .compare-table td {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--border-subtle);
        color: var(--text-secondary);
    }

    .compare-table td:first-child {
        font-weight: 600;
        color: var(--text-heading);
        white-space: nowrap;
    }

    .compare-table tbody tr:hover {
        background: rgba(var(--color-cta-rgb), 0.03);
    }

    .compare-table tbody tr:last-child td {
        border-bottom: none;
    }

    :global([data-theme="dark"]) .compare-table th {
        background: rgba(var(--color-cta-rgb), 0.12);
    }

    :global([data-theme="dark"]) .compare-scroll {
        border-color: var(--border-subtle);
    }
</style>
