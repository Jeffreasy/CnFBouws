---
import { SITE } from "../../data/site";
import { SCHUCO_PROFILES, PRODUCT_CATEGORIES } from "../../data/products";
import Section from "../ui/Section.astro";
import Grid from "../ui/Grid.astro";
import Card from "../ui/Card.astro";
import Tag from "../ui/Tag.astro";
import Icon from "../ui/Icon.astro";
---

<Section
    id="producten"
    tag="Onze Producten"
    title="Kunststof kozijnen, deuren & schuifpuien"
    subtitle="Wij leveren een compleet assortiment kunststof gevelelementen van het merk Schüco — van kozijnen en deuren tot schuifpuien en sierpanelen."
>
    <Grid cols="auto" gap="lg" stagger class="products-grid">
        {
            PRODUCT_CATEGORIES.map((cat) => (
                <Card center variant="feature">
                    <div class="icon-box icon-box--xl product-icon">
                        <Icon name={cat.icon} size={32} strokeWidth={1.5} />
                    </div>
                    <h3 class="card-title product-title">{cat.name}</h3>
                    <p class="card-desc">{cat.description}</p>
                </Card>
            ))
        }
    </Grid>

    <!-- Schüco Profiles -->
    <div class="schuco-section">
        <div class="section-header schuco-header">
            <span class="section-tag">{SITE.schuco.tagline}</span>
            <h3 class="schuco-title">{SITE.schuco.title}</h3>
            <p class="section-subtitle">{SITE.schuco.description}</p>
        </div>

        <Grid cols={3} gap="lg">
            {
                SCHUCO_PROFILES.map((profile) => (
                    <Card bottomBar>
                        <div class="profile-header">
                            <Tag variant="cta">{profile.subtitle}</Tag>
                            <h4 class="profile-name">{profile.name}</h4>
                        </div>
                        <p class="card-desc profile-desc">
                            {profile.description}
                        </p>
                        <p class="profile-best-for">
                            <strong>Ideaal voor:</strong> {profile.bestFor}
                        </p>
                        <ul class="feature-list">
                            {profile.features.map((f) => (
                                <li class="feature-item">
                                    <Icon
                                        name="check"
                                        size={14}
                                        strokeWidth={3}
                                    />
                                    {f}
                                </li>
                            ))}
                        </ul>
                    </Card>
                ))
            }
        </Grid>
    </div>
</Section>

<style>
    .product-icon {
        margin: 0 auto 1.25rem;
    }
    .product-title {
        font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
    }

    .schuco-section {
        margin-top: clamp(2.5rem, 6vw, 5rem);
        padding-top: 2rem;
        border-top: 1px solid var(--border-subtle);
    }
    .schuco-header {
        margin: 2.5rem auto 3rem;
    }
    .schuco-title {
        font-size: clamp(1.5rem, 3vw, 2rem);
        margin-bottom: 0.75rem;
    }

    .profile-header {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.625rem;
        margin-bottom: 1rem;
    }
    .profile-name {
        font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    }
    .profile-desc {
        margin-bottom: 0.875rem;
    }
    .profile-best-for {
        font-size: clamp(0.8125rem, 1.2vw, 0.875rem);
        color: var(--text-muted);
        margin-bottom: 1.125rem;
        padding: 0.5rem 0.875rem;
        background: rgba(var(--color-cta-rgb), 0.04);
        border-radius: var(--radius-sm);
        border-left: 3px solid var(--color-cta);
    }
    .profile-best-for strong {
        color: var(--text-primary);
    }
</style>
