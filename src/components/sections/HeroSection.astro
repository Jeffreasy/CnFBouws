---
import { SITE } from "../../data/site";
---

<section class="hero" id="hero">
    <div class="hero-bg">
        <div class="hero-gradient"></div>
        <div class="hero-grid"></div>
    </div>

    <div class="container hero-content">
        <div class="hero-badge">
            <span class="badge-dot"></span>
            {SITE.hero.badge}
        </div>

        <h1 class="hero-title">
            <span class="title-line">{SITE.hero.titleLine1}</span>
            <span class="title-line title-accent">{SITE.hero.titleLine2}</span>
        </h1>

        <p class="hero-subtitle">{SITE.hero.subtitle}</p>

        <div class="hero-actions">
            <a href={SITE.cta.primary.href} class="btn btn-primary btn-lg">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                    ></path><polyline points="22,6 12,13 2,6"></polyline></svg
                >
                {SITE.cta.primary.label}
            </a>
            <a
                href={SITE.contact.whatsappHref}
                class="btn btn-secondary btn-lg"
                target="_blank"
                rel="noopener noreferrer"
            >
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"
                    ></path></svg
                >
                WhatsApp
            </a>
        </div>

        <div class="hero-stats">
            {
                SITE.hero.stats.map((stat, i) => (
                    <>
                        {i > 0 && <div class="stat-divider" />}
                        <div class="stat-item">
                            <span class="stat-value">{stat.value}</span>
                            <span class="stat-label">{stat.label}</span>
                        </div>
                    </>
                ))
            }
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 7rem 0 4rem;
        overflow: hidden;
    }
    .hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
    }
    .hero-gradient {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(
                ellipse 80% 60% at 20% 40%,
                rgba(3, 105, 161, 0.15),
                transparent 60%
            ),
            radial-gradient(
                ellipse 60% 80% at 80% 60%,
                rgba(245, 158, 11, 0.08),
                transparent 60%
            ),
            radial-gradient(
                ellipse 100% 50% at 50% 100%,
                rgba(3, 105, 161, 0.08),
                transparent
            );
    }
    .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(148, 163, 184, 0.08) 1px, transparent 1px),
            linear-gradient(
                90deg,
                rgba(148, 163, 184, 0.08) 1px,
                transparent 1px
            );
        background-size: 60px 60px;
        mask-image: radial-gradient(
            ellipse 80% 60% at 50% 40%,
            black 20%,
            transparent 70%
        );
        -webkit-mask-image: radial-gradient(
            ellipse 80% 60% at 50% 40%,
            black 20%,
            transparent 70%
        );
    }
    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 700px;
    }
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.25rem;
        background: var(--surface-card);
        border: 1px solid var(--border-card);
        border-radius: var(--radius-full);
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--color-cta);
        margin-bottom: 1.5rem;
        animation: fadeInUp 0.6s ease-out;
        box-shadow: var(--shadow-sm);
    }
    .badge-dot {
        width: 7px;
        height: 7px;
        background: var(--color-accent);
        border-radius: 50%;
        animation: pulse-dot 2s infinite;
        box-shadow: 0 0 6px rgba(245, 158, 11, 0.5);
    }
    .hero-title {
        font-size: clamp(2.5rem, 5.5vw, 4.25rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 1.5rem;
        animation: fadeInUp 0.6s ease-out 0.1s both;
    }
    .title-line {
        display: block;
    }
    .title-accent {
        background: linear-gradient(
            135deg,
            var(--color-cta),
            #38bdf8,
            var(--color-accent)
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .hero-subtitle {
        font-size: 1.1875rem;
        color: var(--text-secondary);
        max-width: 560px;
        margin-bottom: 2.25rem;
        line-height: 1.75;
        animation: fadeInUp 0.6s ease-out 0.2s both;
    }
    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.875rem;
        margin-bottom: 3rem;
        animation: fadeInUp 0.6s ease-out 0.3s both;
    }
    .hero-stats {
        display: flex;
        align-items: center;
        gap: 2rem;
        padding: 1.5rem 2.5rem;
        background: var(--surface-card);
        border: 1px solid var(--border-card);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        animation: fadeInUp 0.6s ease-out 0.4s both;
    }
    .stat-item {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
    }
    .stat-value {
        font-family: "Lexend", sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--color-cta);
        line-height: 1.1;
    }
    .stat-label {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .stat-divider {
        width: 1px;
        height: 2.5rem;
        background: var(--border-subtle);
    }

    @media (max-width: 768px) {
        .hero {
            padding: 6rem 0 3rem;
        }
        .hero-stats {
            flex-direction: column;
            gap: 1rem;
            align-items: flex-start;
            padding: 1.25rem 1.5rem;
        }
        .stat-divider {
            width: 100%;
            height: 1px;
        }
    }
</style>
