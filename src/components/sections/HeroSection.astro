---
import { SITE } from "../../data/site";
import Icon from "../ui/Icon.astro";
---

<section class="hero" id="hero">
    <div class="hero-bg">
        <div class="hero-gradient"></div>
        <div class="hero-grid"></div>
    </div>

    <div class="container hero-content">
        <div class="hero-badge">
            <span class="badge-dot"></span>
            {SITE.hero.badge}
        </div>

        <h1 class="hero-title">
            <span class="title-line">{SITE.hero.titleLine1}</span>
            <span class="title-line title-accent">{SITE.hero.titleLine2}</span>
        </h1>

        <p class="hero-subtitle">{SITE.hero.subtitle}</p>

        <div class="hero-actions">
            <button
                type="button"
                data-modal-open="contact-modal"
                class="btn btn-primary btn-lg"
            >
                <Icon name="mail" size={18} />
                {SITE.cta.primary.label}
            </button>
            <a
                href={SITE.contact.whatsappHref}
                class="btn btn-secondary btn-lg"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Stuur een WhatsApp bericht naar ${SITE.contact.phone}`}
            >
                <Icon name="message-circle" size={18} />
                WhatsApp
            </a>
        </div>

        <div class="hero-stats glass-card">
            {
                SITE.hero.stats.map((stat, i) => (
                    <>
                        {i > 0 && <div class="stat-divider" />}
                        <div class="stat-item">
                            <span class="stat-value">{stat.value}</span>
                            <span class="stat-label">{stat.label}</span>
                        </div>
                    </>
                ))
            }
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        padding: 8rem 0 4rem;
        overflow: hidden;
    }
    .hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
    }
    .hero-gradient {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(
                ellipse 80% 60% at 20% 40%,
                rgba(var(--color-cta-rgb), 0.15),
                transparent 60%
            ),
            radial-gradient(
                ellipse 60% 80% at 80% 60%,
                rgba(var(--color-accent-rgb), 0.08),
                transparent 60%
            ),
            radial-gradient(
                ellipse 100% 50% at 50% 100%,
                rgba(var(--color-cta-rgb), 0.08),
                transparent
            );
    }
    .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(var(--border-subtle) 1px, transparent 1px),
            linear-gradient(90deg, var(--border-subtle) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: radial-gradient(
            ellipse 80% 60% at 50% 40%,
            black 20%,
            transparent 70%
        );
        -webkit-mask-image: radial-gradient(
            ellipse 80% 60% at 50% 40%,
            black 20%,
            transparent 70%
        );
    }
    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 700px;
    }
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.25rem;
        background: var(--surface-card);
        border: 1px solid var(--border-card);
        border-radius: var(--radius-full);
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--color-cta);
        margin-bottom: 1.5rem;
        animation: fadeInUp 0.6s ease-out;
        box-shadow: var(--shadow-sm);
    }
    .badge-dot {
        width: 7px;
        height: 7px;
        background: var(--color-accent);
        border-radius: 50%;
        animation: pulse-dot 2s infinite;
        box-shadow: 0 0 6px rgba(var(--color-accent-rgb), 0.5);
    }
    .hero-title {
        font-size: clamp(2.5rem, 5.5vw, 4.25rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 1.5rem;
        animation: fadeInUp 0.6s ease-out 0.1s both;
    }
    .title-line {
        display: block;
    }
    .title-accent {
        background: linear-gradient(
            135deg,
            var(--color-cta),
            var(--color-cta-light),
            var(--color-accent)
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .hero-subtitle {
        font-size: 1.1875rem;
        color: var(--text-secondary);
        max-width: 560px;
        margin-bottom: 2.25rem;
        line-height: 1.75;
        animation: fadeInUp 0.6s ease-out 0.2s both;
    }
    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.875rem;
        margin-bottom: 3rem;
        animation: fadeInUp 0.6s ease-out 0.3s both;
    }
    .hero-stats {
        display: flex;
        align-items: center;
        gap: 2rem;
        padding: 1.5rem 2.5rem;
        animation: fadeInUp 0.6s ease-out 0.4s both;
    }
    .stat-item {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
    }
    .stat-value {
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--color-cta);
        line-height: 1.1;
    }
    .stat-label {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .stat-divider {
        width: 1px;
        height: 2.5rem;
        background: var(--border-subtle);
    }

    @media (max-width: 768px) {
        .hero {
            padding: 7rem 0 3rem;
        }
        .hero-stats {
            flex-direction: column;
            gap: 1rem;
            align-items: flex-start;
            padding: 1.25rem 1.5rem;
        }
        .stat-divider {
            width: 100%;
            height: 1px;
        }
    }

    /* ─── Reduced Motion ─────────────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
        .hero-badge,
        .badge-dot,
        .hero-title,
        .hero-subtitle,
        .hero-actions,
        .hero-stats {
            animation: none !important;
        }
    }
</style>
