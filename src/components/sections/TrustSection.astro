---
/**
 * TrustSection — Keurmerken & Subsidie
 *
 * Layout: Own CSS grid matching ServicesSection pattern exactly.
 * Uses: Section, Card, Tag, Icon primitives
 */
import { KEURMERKEN, SUBSIDIE, TRUST_STATEMENT } from "../../data/keurmerken";
import Section from "../ui/Section.astro";
import Card from "../ui/Card.astro";
import Tag from "../ui/Tag.astro";
import Icon from "../ui/Icon.astro";
---

<Section
    id="keurmerken"
    tag="Kwaliteit & Veiligheid"
    title="Gecertificeerde kwaliteit"
    subtitle={TRUST_STATEMENT}
    muted
>
    <!-- Keurmerk Cards — same grid pattern as ServicesSection -->
    <div
        class="trust-grid"
        style="display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;margin-bottom:3rem;"
    >
        {
            KEURMERKEN.map((k) => (
                <Card center hover="none">
                    <div class="keurmerk-logo-wrap">
                        <img
                            src={k.logo}
                            alt={`${k.name} logo`}
                            class="keurmerk-logo"
                            width="200"
                            height="200"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <h3 class="keurmerk-name">{k.name}</h3>
                    <p class="card-desc">{k.description}</p>
                </Card>
            ))
        }
    </div>

    <!-- Subsidie Banner -->
    <div class="glass-card subsidie-banner">
        <div class="icon-box icon-box--lg icon-box--accent subsidie-icon">
            <Icon name="dollar-sign" size={28} />
        </div>
        <div class="subsidie-content">
            <Tag variant="accent">{SUBSIDIE.tagline}</Tag>
            <h3 class="subsidie-title">{SUBSIDIE.title}</h3>
            <p class="card-desc">{SUBSIDIE.description}</p>
        </div>
    </div>
</Section>

<style>
    /* ─── Logo Container ──────────────────────────────────── */

    .keurmerk-logo-wrap {
        width: 96px;
        height: 96px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-inline: auto;
        margin-bottom: var(--space-lg);
        border-radius: var(--radius-lg);
        background: #fff;
        padding: var(--space-sm);
        box-shadow:
            0 2px 12px rgba(0, 0, 0, 0.08),
            inset 0 1px 0 rgba(255, 255, 255, 0.5);
    }

    .keurmerk-logo {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    /* ─── Typography ──────────────────────────────────────── */

    .keurmerk-name {
        font-family: var(--font-heading);
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--text-heading);
        margin-bottom: var(--space-sm);
        text-align: center;
        line-height: 1.3;
    }

    /* ─── Subsidie Banner ─────────────────────────────────── */

    .subsidie-banner {
        display: flex;
        align-items: flex-start;
        gap: var(--space-xl);
        padding: var(--space-2xl);
        background: linear-gradient(
            135deg,
            rgba(var(--color-accent-rgb), 0.06),
            rgba(var(--color-cta-rgb), 0.04)
        );
        border: 1px solid rgba(var(--color-accent-rgb), 0.2);
    }

    .subsidie-icon {
        flex-shrink: 0;
    }

    .subsidie-title {
        font-size: 1.375rem;
        margin-bottom: var(--space-sm);
    }

    /* ─── Responsive ─────────────────────────────────────── */

    @media (max-width: 1024px) {
        .trust-grid {
            grid-template-columns: repeat(2, 1fr) !important;
        }
    }

    @media (max-width: 768px) {
        .subsidie-banner {
            flex-direction: column;
        }
    }

    @media (max-width: 480px) {
        .trust-grid {
            grid-template-columns: 1fr !important;
        }
    }
</style>
