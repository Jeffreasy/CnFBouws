---
/**
 * TrustSection — Keurmerken & Subsidie
 *
 * Uses existing Card, Grid, Tag, Icon primitives for guaranteed layout.
 * Gold accent treatment for certification authority.
 */
import { KEURMERKEN, SUBSIDIE, TRUST_STATEMENT } from "../../data/keurmerken";
import Section from "../ui/Section.astro";
import Grid from "../ui/Grid.astro";
import Card from "../ui/Card.astro";
import Tag from "../ui/Tag.astro";
import Icon from "../ui/Icon.astro";
---

<Section
    id="keurmerken"
    tag="Kwaliteit & Veiligheid"
    title="Gecertificeerde kwaliteit"
    subtitle={TRUST_STATEMENT}
>
    <!-- Keurmerk Badge Cards -->
    <Grid cols={4} gap="lg">
        {
            KEURMERKEN.map((k) => (
                <Card center hover="lift">
                    <div class="keurmerk-ring">
                        <img
                            src={k.logo}
                            alt={`${k.name} logo`}
                            class="keurmerk-logo"
                            width="200"
                            height="200"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <span class="keurmerk-abbr">{k.abbreviation}</span>
                    <h3 class="keurmerk-name">{k.name}</h3>
                    <p class="card-desc">{k.description}</p>
                </Card>
            ))
        }
    </Grid>

    <!-- Subsidie Banner -->
    <div class="subsidie-banner glass-card">
        <div class="subsidie-stripe"></div>
        <div class="subsidie-body">
            <div class="subsidie-top">
                <div class="icon-box icon-box--lg icon-box--accent">
                    <Icon name="banknote" size={28} />
                </div>
                <div class="subsidie-heading">
                    <Tag variant="accent">{SUBSIDIE.tagline}</Tag>
                    <h3 class="subsidie-title">{SUBSIDIE.title}</h3>
                </div>
            </div>
            <p class="card-desc">{SUBSIDIE.description}</p>
        </div>
    </div>
</Section>

<style>
    /* ─── Logo Ring ──────────────────────────────────────── */

    .keurmerk-ring {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px;
        margin: 0 auto 1rem;
        background: var(--surface-elevated);
        border: 2px solid var(--border-subtle);
        border-radius: 50%;
        box-shadow:
            inset 0 1px 2px rgba(0, 0, 0, 0.04),
            0 2px 8px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .keurmerk-logo {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    /* ─── Badge Abbreviation ─────────────────────────────── */

    .keurmerk-abbr {
        display: inline-block;
        font-family: var(--font-heading);
        font-size: 0.625rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #9a7c3a;
        background: rgba(200, 160, 78, 0.1);
        border: 1px solid rgba(200, 160, 78, 0.18);
        padding: 0.15rem 0.625rem;
        border-radius: var(--radius-full);
        margin-bottom: 0.5rem;
    }

    .keurmerk-name {
        font-family: var(--font-heading);
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--text-heading);
        margin-bottom: var(--space-sm);
        line-height: 1.3;
    }

    /* ─── Subsidie Banner ────────────────────────────────── */

    .subsidie-banner {
        margin-top: 3rem;
        display: flex;
        overflow: hidden;
    }

    .subsidie-stripe {
        width: 5px;
        flex-shrink: 0;
        background: linear-gradient(
            180deg,
            var(--color-accent),
            var(--color-cta)
        );
    }

    .subsidie-body {
        padding: 2rem 2.5rem;
        flex: 1;
    }

    .subsidie-top {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.875rem;
    }

    .subsidie-heading {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .subsidie-title {
        font-size: 1.25rem;
        font-family: var(--font-heading);
        font-weight: 700;
        color: var(--text-heading);
    }

    /* ─── Dark Mode ──────────────────────────────────────── */

    [data-theme="dark"] .keurmerk-abbr {
        color: #e8c86a;
        background: rgba(200, 160, 78, 0.15);
        border-color: rgba(200, 160, 78, 0.25);
    }

    [data-theme="dark"] .keurmerk-ring {
        background: rgba(255, 255, 255, 0.05);
    }

    /* ─── Responsive ─────────────────────────────────────── */

    @media (max-width: 768px) {
        .subsidie-banner {
            flex-direction: column;
        }

        .subsidie-stripe {
            width: 100%;
            height: 4px;
        }

        .subsidie-body {
            padding: 1.5rem;
        }

        .subsidie-top {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
