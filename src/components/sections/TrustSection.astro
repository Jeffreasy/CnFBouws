---
import { KEURMERKEN, SUBSIDIE, TRUST_STATEMENT } from "../../data/keurmerken";
import Section from "../ui/Section.astro";
import Grid from "../ui/Grid.astro";
import Card from "../ui/Card.astro";
import Tag from "../ui/Tag.astro";
import Icon from "../ui/Icon.astro";
---

<Section
    id="keurmerken"
    tag="Kwaliteit & Veiligheid"
    title="Gecertificeerde kwaliteit"
    subtitle={TRUST_STATEMENT}
    muted
>
    <Grid cols={4} gap="lg" stagger class="keurmerken-grid">
        {
            KEURMERKEN.map((k) => (
                <Card center>
                    <div class="icon-box icon-box--md keurmerk-icon">
                        <Icon name="shield" size={24} />
                    </div>
                    <span class="keurmerk-abbr">{k.abbreviation}</span>
                    <h4 class="keurmerk-name">{k.name}</h4>
                    <p class="card-desc">{k.description}</p>
                </Card>
            ))
        }
    </Grid>

    <!-- Subsidie Banner -->
    <div class="glass-card subsidie-banner">
        <div class="icon-box icon-box--lg icon-box--accent">
            <Icon name="dollar-sign" size={28} />
        </div>
        <div class="subsidie-content">
            <Tag variant="accent">{SUBSIDIE.tagline}</Tag>
            <h3 class="subsidie-title">{SUBSIDIE.title}</h3>
            <p class="card-desc">{SUBSIDIE.description}</p>
        </div>
    </div>
</Section>

<style>
    .keurmerken-grid {
        margin-bottom: 3rem;
    }
    .keurmerk-icon {
        margin: 0 auto 1rem;
    }
    .keurmerk-abbr {
        display: block;
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--color-cta);
        margin-bottom: 0.375rem;
    }
    .keurmerk-name {
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text-muted);
        margin-bottom: 0.625rem;
    }

    .subsidie-banner {
        display: flex;
        align-items: flex-start;
        gap: 1.75rem;
        padding: 2.5rem;
        background: linear-gradient(
            135deg,
            rgba(var(--color-accent-rgb), 0.06),
            rgba(var(--color-cta-rgb), 0.04)
        );
        border: 1px solid rgba(var(--color-accent-rgb), 0.2);
    }
    .subsidie-title {
        font-size: 1.375rem;
        margin-bottom: 0.5rem;
    }

    @media (max-width: 768px) {
        .subsidie-banner {
            flex-direction: column;
        }
    }
</style>
