---
/**
 * TrustSection — Keurmerken & Subsidie
 *
 * Compact badge layout for certification marks.
 * Uses proven Grid primitive for layout, lightweight badge divs for content.
 * Gold accent via CSS custom properties for maintainability.
 */
import { KEURMERKEN, SUBSIDIE, TRUST_STATEMENT } from "../../data/keurmerken";
import Section from "../ui/Section.astro";
import Grid from "../ui/Grid.astro";
import Icon from "../ui/Icon.astro";
---

<Section
    id="keurmerken"
    tag="Kwaliteit & Veiligheid"
    title="Gecertificeerde kwaliteit"
    subtitle={TRUST_STATEMENT}
>
    <!-- Keurmerk Badges -->
    <Grid cols={4} gap="md" stagger>
        {
            KEURMERKEN.map((k) => (
                <div class="keurmerk-badge">
                    <img
                        src={k.logo}
                        alt={`${k.name} keurmerk`}
                        class="keurmerk-logo"
                        loading="lazy"
                        decoding="async"
                    />
                    <span class="keurmerk-abbr">{k.abbreviation}</span>
                    <span class="keurmerk-name">{k.name}</span>
                    <span class="keurmerk-desc">{k.description}</span>
                </div>
            ))
        }
    </Grid>

    <!-- Subsidie Banner — Prominent split layout -->
    <div class="subsidie-banner">
        <div class="subsidie-accent">
            <div class="subsidie-accent-icon">
                <Icon name="banknote" size={32} />
            </div>
            <span class="subsidie-accent-tag">{SUBSIDIE.tagline}</span>
        </div>
        <div class="subsidie-body">
            <h3 class="subsidie-title">{SUBSIDIE.title}</h3>
            <p class="card-desc subsidie-desc">{SUBSIDIE.description}</p>
            <a href={SUBSIDIE.rvoUrl} target="_blank" rel="noopener noreferrer" class="subsidie-btn">
                Bekijk op rvo.nl
                <Icon name="arrow-right" size={16} />
            </a>
        </div>
    </div>
</Section>

<style>
    /* ─── Gold accent tokens (scoped to keurmerk badges) ── */

    .keurmerk-badge {
        --gold-base: 200, 160, 78;
        --gold-text: #9a7c3a; /* light mode */
    }

    :global([data-theme="dark"]) .keurmerk-badge {
        --gold-text: #e8c86a; /* dark mode — lighter gold for dark bg */
    }

    /* ─── Compact Badge ──────────────────────────────────── */

    .keurmerk-badge {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 1.25rem 1rem;
        background: var(--surface-elevated);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-md);
        transition:
            border-color var(--transition-normal),
            box-shadow var(--transition-normal);
        cursor: default;
    }

    .keurmerk-badge:hover {
        border-color: rgba(var(--gold-base), 0.35);
        box-shadow: 0 2px 12px rgba(var(--gold-base), 0.08);
    }

    /* ─── Logo ────────────────────────────────────────────── */

    .keurmerk-logo {
        width: auto;
        max-width: 100%;
        height: auto;
        max-height: 80px;
        object-fit: contain;
        margin-bottom: 0.75rem;
    }

    /* ─── Badge Text ─────────────────────────────────────── */

    .keurmerk-abbr {
        display: inline-block;
        font-family: var(--font-heading);
        font-size: 0.5625rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gold-text);
        background: rgba(var(--gold-base), 0.1);
        border: 1px solid rgba(var(--gold-base), 0.18);
        padding: 0.1rem 0.5rem;
        border-radius: var(--radius-full);
        margin-bottom: 0.375rem;
    }

    .keurmerk-name {
        font-family: var(--font-heading);
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text-heading);
        line-height: 1.3;
        margin-bottom: 0.5rem;
    }

    .keurmerk-desc {
        font-size: 0.75rem;
        color: var(--text-muted);
        line-height: 1.5;
    }

    /* ─── Subsidie Banner ────────────────────────────────── */

    .subsidie-banner {
        margin-top: 2.5rem;
        display: flex;
        flex-direction: column;
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-md);
    }

    /* Left/top accent panel */
    .subsidie-accent {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 2rem 1.5rem;
        background: linear-gradient(
            135deg,
            var(--color-primary),
            var(--color-secondary)
        );
        color: #fff;
    }

    .subsidie-accent-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
    }

    .subsidie-accent-tag {
        font-family: var(--font-heading);
        font-size: 0.6875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(255, 255, 255, 0.9);
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 0.25rem 0.875rem;
        border-radius: var(--radius-full);
    }

    /* Right/bottom content panel */
    .subsidie-body {
        padding: 1.75rem 1.5rem;
        flex: 1;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.625rem;
        background: var(--surface-card);
    }

    .subsidie-title {
        font-size: clamp(1.125rem, 2.5vw, 1.375rem);
        font-family: var(--font-heading);
        font-weight: 700;
        color: var(--text-heading);
    }

    .subsidie-desc {
        max-width: 480px;
    }

    .subsidie-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
        padding: 0.625rem 1.25rem;
        font-family: var(--font-heading);
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--color-cta);
        text-decoration: none;
        border: 1.5px solid var(--color-cta);
        border-radius: var(--radius-md);
        transition: background 0.2s ease, color 0.2s ease;
    }

    .subsidie-btn:hover {
        background: var(--color-cta);
        color: #fff;
    }

    /* Desktop (>=769px): side-by-side */
    @media (min-width: 769px) {
        .subsidie-banner {
            flex-direction: row;
        }
        .subsidie-accent {
            width: 220px;
            flex-shrink: 0;
            padding: 2.5rem 2rem;
        }
        .subsidie-body {
            padding: 2rem 2.5rem;
            text-align: left;
            align-items: flex-start;
        }
    }

    /* ─── Dark Mode ──────────────────────────────────────── */

    :global([data-theme="dark"]) .keurmerk-badge {
        background: rgba(255, 255, 255, 0.03);
        border-color: var(--border-subtle);
    }

    :global([data-theme="dark"]) .keurmerk-badge:hover {
        border-color: rgba(var(--gold-base), 0.3);
        box-shadow: 0 2px 12px rgba(var(--gold-base), 0.06);
    }

    :global([data-theme="dark"]) .keurmerk-abbr {
        color: var(--gold-text);
        background: rgba(var(--gold-base), 0.15);
        border-color: rgba(var(--gold-base), 0.25);
    }

    /* ─── Reduced Motion ─────────────────────────────────── */

    @media (prefers-reduced-motion: reduce) {
        .keurmerk-badge {
            transition: none;
        }
    }
</style>
