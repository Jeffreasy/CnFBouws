---
import { SITE } from "../../data/site";
import Section from "../ui/Section.astro";
import Icon from "../ui/Icon.astro";
---

<Section id="contact">
    <div class="cta-card glass-card">
        <div class="cta-glow"></div>
        <div class="cta-content">
            <h2 class="cta-title">Vrijblijvend advies of offerte?</h2>
            <p class="cta-text">
                Neem contact met ons op voor een persoonlijke offerte, afspraak
                voor adviesgesprek en inmeten, of bezoek onze showroom. Wij
                denken graag met u mee.
            </p>

            <div class="cta-actions">
                <a href={SITE.contact.emailHref} class="btn btn-primary btn-lg">
                    <Icon name="mail" size={18} />
                    Offerte Aanvragen
                </a>
                <a
                    href={SITE.contact.phoneHref}
                    class="btn btn-secondary btn-lg"
                >
                    <Icon name="phone" size={18} />
                    Bel Direct
                </a>
                <a
                    href={SITE.contact.whatsappHref}
                    class="btn btn-secondary btn-lg"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <Icon name="message-circle" size={18} />
                    WhatsApp
                </a>
            </div>

            <p class="cta-contact-info">
                <Icon name="mail" size={14} class="cta-info-icon" />
                {SITE.contact.email} &nbsp;|&nbsp;
                <Icon name="phone" size={14} class="cta-info-icon" />
                {SITE.contact.phone}
            </p>
        </div>
    </div>
</Section>

<style>
    .cta-card {
        position: relative;
        padding: 5rem 4rem;
        text-align: center;
        overflow: hidden;
        background: linear-gradient(
            135deg,
            var(--surface-card),
            var(--surface-elevated)
        );
        border: 1px solid var(--border-card);
    }
    .cta-glow {
        position: absolute;
        top: -40%;
        left: 50%;
        transform: translateX(-50%);
        width: 500px;
        height: 500px;
        background: radial-gradient(
            circle,
            rgba(var(--color-cta-rgb), 0.15),
            transparent 55%
        );
        pointer-events: none;
    }
    .cta-content {
        position: relative;
        z-index: 1;
    }

    .cta-title {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        margin-bottom: 1.25rem;
    }
    .cta-text {
        color: var(--text-secondary);
        font-size: 1.0625rem;
        line-height: 1.75;
        max-width: 560px;
        margin: 0 auto 2.5rem;
    }
    .cta-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.875rem;
        margin-bottom: 2rem;
    }

    .cta-contact-info {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: var(--text-muted);
        padding: 0.5rem 1rem;
        background: rgba(var(--color-cta-rgb), 0.04);
        border-radius: var(--radius-full);
        border: 1px solid var(--border-subtle);
    }
    .cta-contact-info :global(.cta-info-icon) {
        opacity: 0.6;
        color: var(--color-cta);
    }

    @media (max-width: 768px) {
        .cta-card {
            padding: 3rem 1.5rem;
        }
        .cta-actions {
            flex-direction: column;
        }
    }
</style>
