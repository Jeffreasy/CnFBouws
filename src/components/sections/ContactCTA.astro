---
import { SITE } from "../../data/site";
---

<section class="cta" id="contact">
    <div class="container">
        <div class="cta-card glass-card">
            <div class="cta-glow"></div>
            <div class="cta-content">
                <h2 class="cta-title">Vrijblijvend advies of offerte?</h2>
                <p class="cta-text">
                    Neem contact met ons op voor een persoonlijke offerte,
                    afspraak voor adviesgesprek en inmeten, of bezoek onze
                    showroom. Wij denken graag met u mee.
                </p>

                <div class="cta-actions">
                    <a
                        href={SITE.contact.emailHref}
                        class="btn btn-primary btn-lg"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                            ></path><polyline points="22,6 12,13 2,6"
                            ></polyline></svg
                        >
                        Offerte Aanvragen
                    </a>
                    <a
                        href={SITE.contact.phoneHref}
                        class="btn btn-secondary btn-lg"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
                            ></path></svg
                        >
                        Bel Direct
                    </a>
                    <a
                        href={SITE.contact.whatsappHref}
                        class="btn btn-secondary btn-lg"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"
                            ></path></svg
                        >
                        WhatsApp
                    </a>
                </div>

                <p class="cta-contact-info">
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                        ></path><polyline points="22,6 12,13 2,6"
                        ></polyline></svg
                    >
                    {SITE.contact.email} &nbsp;|&nbsp;
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
                        ></path></svg
                    >
                    {SITE.contact.phone}
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .cta {
        padding: 6rem 0;
    }

    .cta-card {
        position: relative;
        padding: 5rem 4rem;
        text-align: center;
        overflow: hidden;
        background: linear-gradient(
            135deg,
            var(--surface-card),
            var(--surface-elevated)
        );
        border: 1px solid var(--border-card);
    }
    .cta-glow {
        position: absolute;
        top: -40%;
        left: 50%;
        transform: translateX(-50%);
        width: 500px;
        height: 500px;
        background: radial-gradient(
            circle,
            rgba(3, 105, 161, 0.15),
            transparent 55%
        );
        pointer-events: none;
    }
    .cta-content {
        position: relative;
        z-index: 1;
    }

    .cta-title {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        margin-bottom: 1.25rem;
    }
    .cta-text {
        color: var(--text-secondary);
        font-size: 1.0625rem;
        line-height: 1.75;
        max-width: 560px;
        margin: 0 auto 2.5rem;
    }
    .cta-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.875rem;
        margin-bottom: 2rem;
    }

    .cta-contact-info {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: var(--text-muted);
        padding: 0.5rem 1rem;
        background: rgba(3, 105, 161, 0.04);
        border-radius: var(--radius-full);
        border: 1px solid var(--border-subtle);
    }
    .cta-contact-info svg {
        opacity: 0.6;
        color: var(--color-cta);
    }

    @media (max-width: 768px) {
        .cta-card {
            padding: 3rem 1.5rem;
        }
        .cta-actions {
            flex-direction: column;
        }
    }
</style>
