---
/**
 * WerkwijzeSection — Premium 4-step process
 * Markup only. All styles live in global.css (.wz-* classes).
 */
import { WERKWIJZE } from "../../data/services";
---

<section id="werkwijze" class="wz-section">
    <div class="wz-container">

        <div class="wz-header">
            <span class="wz-tag">Ons Proces</span>
            <h2 class="wz-title">Van contact tot oplevering</h2>
            <p class="wz-sub">Een helder, transparant proces — zodat u altijd weet waar u aan toe bent.</p>
        </div>

        <div class="wz-steps">
            {WERKWIJZE.map((step, i) => (
                <article class={`wz-card wz-card--${i}`}>

                    <div class="wz-num">{step.step}</div>

                    <div class="wz-icon">
                        {step.icon === 'calendar' && (
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        )}
                        {step.icon === 'ruler' && (
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z"/><path d="M20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                        )}
                        {step.icon === 'file-text' && (
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                        )}
                        {step.icon === 'check-circle' && (
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        )}
                    </div>

                    <h3 class="wz-step-title">{step.title}</h3>
                    <p class="wz-step-desc">{step.description}</p>

                </article>
            ))}
        </div>

    </div>
</section>
