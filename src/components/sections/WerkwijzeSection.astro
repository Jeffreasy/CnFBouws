---
/**
 * WerkwijzeSection — Premium 4-step process
 * Markup only. All styles live in global.css (.wz-* classes).
 */
import { WERKWIJZE } from "../../data/services";
import Icon from "../ui/Icon.astro";
---

<section id="werkwijze" class="wz-section">
    <div class="wz-container">

        <div class="wz-header">
            <span class="wz-tag">Ons Proces</span>
            <h2 class="wz-title">Van contact tot oplevering</h2>
            <p class="wz-sub">Een helder, transparant proces — zodat u altijd weet waar u aan toe bent.</p>
        </div>

        <div class="wz-steps">
            {WERKWIJZE.map((step, i) => (
                <article class={`wz-card wz-card--${i}`}>

                    <div class="wz-num">{step.step}</div>

                    <div class="wz-icon">
                        <Icon name={step.icon} size={22} strokeWidth={1.75} />
                    </div>

                    <h3 class="wz-step-title">{step.title}</h3>
                    <p class="wz-step-desc">{step.description}</p>

                </article>
            ))}
        </div>

    </div>
</section>
