---
import { WERKWIJZE } from "../../data/services";
import Section from "../ui/Section.astro";
import Grid from "../ui/Grid.astro";
import Card from "../ui/Card.astro";
import Icon from "../ui/Icon.astro";
---

<Section
    id="werkwijze"
    tag="Werkwijze"
    title="Duidelijk en overzichtelijk proces"
    subtitle="Van eerste contact tot oplevering — wij hanteren een heldere werkwijze zodat u altijd weet waar u aan toe bent."
>
    <Grid cols={4} gap="lg" stagger>
        {
            WERKWIJZE.map((step) => (
                <Card center class="werkwijze-step">
                    <div class="step-header">
                        <div class="step-number">{step.step}</div>
                        <div class="icon-box icon-box--sm step-icon">
                            <Icon name={step.icon} size={14} />
                        </div>
                    </div>
                    <div class="step-content">
                        <h3 class="card-title">{step.title}</h3>
                        <p class="card-desc">{step.description}</p>
                    </div>
                    {step.step < 4 && <div class="step-connector" />}
                </Card>
            ))
        }
    </Grid>
</Section>

<style>
    .step-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.625rem;
        margin-bottom: 1.25rem;
    }
    .step-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        background: linear-gradient(
            135deg,
            var(--color-cta),
            var(--color-cta-light)
        );
        color: var(--text-on-cta);
        font-family: var(--font-heading);
        font-size: 1.25rem;
        font-weight: 800;
        border-radius: 50%;
        box-shadow: 0 4px 16px rgba(var(--color-cta-rgb), 0.35);
    }
    .step-icon {
        opacity: 0.7;
    }

    .step-connector {
        display: none;
    }
    @media (min-width: 769px) {
        .step-connector {
            display: block;
            position: absolute;
            top: calc(2.5rem + 28px);
            right: -0.75rem;
            width: 1.5rem;
            height: 2px;
            background: var(--color-cta);
            opacity: 0.25;
        }
    }

    @media (max-width: 768px) {
        .werkwijze-step {
            text-align: left;
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 1rem;
            padding: 1.5rem;
        }
        .step-header {
            flex-direction: column;
            align-items: center;
        }
        .step-number {
            width: 48px;
            height: 48px;
            font-size: 1.125rem;
        }
    }
</style>
