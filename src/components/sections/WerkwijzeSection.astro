---
/**
 * WerkwijzeSection — 4-step process timeline
 *
 * Uses: Section, Grid, Card, Icon primitives
 * Design tokens: --space-*, --color-cta-*, --font-heading, --radius-*
 */
import { WERKWIJZE } from "../../data/services";
import Section from "../ui/Section.astro";
import Grid from "../ui/Grid.astro";
import Card from "../ui/Card.astro";
import Icon from "../ui/Icon.astro";
---

<Section
    id="werkwijze"
    tag="Ons Proces"
    title="Duidelijk en overzichtelijk proces"
    subtitle="Van eerste contact tot oplevering — wij hanteren een heldere werkwijze zodat u altijd weet waar u aan toe bent."
    muted
>
    <Grid cols={4} gap="lg" stagger>
        {
            WERKWIJZE.map((step, index) => (
                <Card center class="werkwijze-step">
                    <div class="step-header">
                        <div class="step-number" aria-hidden="true">
                            {step.step}
                        </div>
                        <div class="icon-box icon-box--sm step-icon">
                            <Icon name={step.icon} size={14} />
                        </div>
                    </div>
                    <div class="step-content">
                        <h3 class="card-title">{step.title}</h3>
                        <p class="card-desc">{step.description}</p>
                    </div>
                    {index < WERKWIJZE.length - 1 && (
                        <div class="step-connector" aria-hidden="true" />
                    )}
                </Card>
            ))
        }
    </Grid>
</Section>

<style>
    /* ── Step Header ──────────────────────────────────────── */
    .werkwijze-step {
        position: relative;
    }

    .step-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-sm);
        margin-bottom: var(--space-lg);
    }

    .step-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        background: linear-gradient(
            135deg,
            var(--color-cta),
            var(--color-cta-light)
        );
        color: var(--text-on-cta);
        font-family: var(--font-heading);
        font-size: 1.25rem;
        font-weight: 800;
        border-radius: 50%;
        box-shadow: 0 4px 16px rgba(var(--color-cta-rgb), 0.35);
    }

    .step-icon {
        opacity: 0.7;
    }

    /* ── Connector Line ──────────────────────────────────── */

    .step-connector {
        display: none;
    }

    @media (min-width: 769px) {
        .step-connector {
            display: block;
            position: absolute;
            top: calc(var(--space-xl) + 28px);
            right: calc(var(--space-sm) * -1);
            width: var(--space-md);
            height: 2px;
            background: var(--color-cta);
            opacity: 0.25;
        }
    }

    /* ── Mobile: Horizontal card layout ──────────────────── */

    @media (max-width: 768px) {
        .werkwijze-step {
            text-align: left;
            display: grid;
            grid-template-columns: auto 1fr;
            gap: var(--space-md);
            padding: var(--space-lg);
            position: relative;
        }

        .step-header {
            flex-direction: column;
            align-items: center;
        }

        .step-number {
            width: 48px;
            height: 48px;
            font-size: 1.125rem;
        }
    }
</style>
