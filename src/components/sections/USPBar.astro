---
/**
 * USPBar — Horizontal strip showing 4 unique selling points
 * Appears between Hero and Services for immediate trust
 */
import { USP_LIST } from "../../data/services";
import Icon from "../ui/Icon.astro";
import Grid from "../ui/Grid.astro";
---

<div class="usp-bar">
    <div class="container">
        <Grid cols={4} gap="md">
            {
                USP_LIST.map((usp) => (
                    <div class="usp-item">
                        <div class="icon-box icon-box--sm">
                            <Icon name={usp.icon} size={16} />
                        </div>
                        <div class="usp-content">
                            <span class="usp-title">{usp.title}</span>
                            <span class="usp-desc">{usp.description}</span>
                        </div>
                    </div>
                ))
            }
        </Grid>
    </div>
</div>

<style>
    .usp-bar {
        background: var(--color-primary);
        padding: 1.25rem 0;
        position: relative;
        z-index: 1;
    }

    /* Bottom bleed: smooth blue → transparent fade into next section */
    .usp-bar::after {
        content: "";
        position: absolute;
        bottom: -60px;
        left: 0;
        right: 0;
        height: 60px;
        background: linear-gradient(
            to bottom,
            var(--color-primary),
            transparent
        );
        pointer-events: none;
        z-index: 0;
    }
    .usp-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--text-on-brand);
    }
    .usp-item :global(.icon-box) {
        background: var(--on-brand-glass);
        border-color: var(--on-brand-border);
        color: var(--color-accent);
    }
    .usp-title {
        display: block;
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: 0.875rem;
        line-height: 1.2;
    }
    .usp-desc {
        display: block;
        font-size: 0.75rem;
        color: var(--text-on-brand-muted);
        line-height: 1.3;
    }
</style>
