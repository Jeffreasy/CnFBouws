---
/**
 * USPBar — Horizontal strip showing 4 unique selling points
 * Appears between Hero and Services for immediate trust
 */
import { USP_LIST } from "../../data/services";
import Icon from "../ui/Icon.astro";
import Grid from "../ui/Grid.astro";
---

<div class="usp-bar">
    <div class="container">
        <Grid cols={4} gap="md">
            {
                USP_LIST.map((usp) => (
                    <div class="usp-item">
                        <div class="icon-box icon-box--sm">
                            <Icon name={usp.icon} size={16} />
                        </div>
                        <div class="usp-content">
                            <span class="usp-title">{usp.title}</span>
                            <span class="usp-desc">{usp.description}</span>
                        </div>
                    </div>
                ))
            }
        </Grid>
    </div>
</div>

<style>
    .usp-bar {
        background: var(--color-primary);
        padding: 1.25rem 0;
        position: relative;
        z-index: 1;
        border-bottom: 1px solid rgba(0, 0, 0, 0.12);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.18);
    }

    /* Light mode: subtle top-fade to soften the hero→USPbar cut */
    .usp-bar::before {
        content: '';
        position: absolute;
        top: -20px;
        left: 0;
        right: 0;
        height: 20px;
        background: linear-gradient(
            to bottom,
            transparent,
            rgba(var(--color-primary-rgb), 0.25)
        );
        pointer-events: none;
    }

    /* Dark mode: the bg-to-bg transition is already smooth — remove fade */
    :global([data-theme="dark"]) .usp-bar::before {
        display: none;
    }

    .usp-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--text-on-brand);
    }
    .usp-item :global(.icon-box) {
        background: var(--on-brand-glass);
        border-color: var(--on-brand-border);
        color: var(--color-accent);
    }
    .usp-title {
        display: block;
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: clamp(0.8125rem, 1.5vw, 0.875rem); /* fluid */
        line-height: 1.2;
    }
    .usp-desc {
        display: block;
        font-size: clamp(0.6875rem, 1.2vw, 0.75rem); /* fluid */
        color: var(--text-on-brand-muted);
        line-height: 1.3;
    }
</style>
