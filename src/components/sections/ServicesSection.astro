---
import { SERVICES } from "../../data/services";
import Section from "../ui/Section.astro";
import Card from "../ui/Card.astro";
import Icon from "../ui/Icon.astro";

// Split services into logical groups
const producten = SERVICES.filter((s) =>
    ["kozijnen", "deuren", "schuifpuien"].includes(s.id),
);
const diensten = SERVICES.filter(
    (s) => !["kozijnen", "deuren", "schuifpuien"].includes(s.id),
);
---

<Section
    id="diensten"
    tag="Onze Diensten"
    title="Complete service van advies tot oplevering"
    subtitle="C&F Bouw verzorgt het complete traject rondom kunststof kozijnen en aanverwante producten. Dankzij onze efficiënte werkwijze kunnen wij snel schakelen."
    muted
>
    <!-- Producten — 3 featured cards -->
    <div class="services-group">
        <h3 class="services-group-label">
            <span class="services-group-label-line"></span>
            Producten
            <span class="services-group-label-line"></span>
        </h3>
        <div class="services-products">
            {
                producten.map((service) => (
                    <Card accentBar>
                        <div class="icon-box icon-box--lg service-icon">
                            <Icon name={service.icon} size={28} />
                        </div>
                        <h3 class="card-title">{service.title}</h3>
                        <p class="card-desc">{service.description}</p>
                    </Card>
                ))
            }
        </div>
    </div>

    <!-- Service Process — 4 cards -->
    <div class="services-group">
        <h3 class="services-group-label">
            <span class="services-group-label-line"></span>
            Ons Proces
            <span class="services-group-label-line"></span>
        </h3>
        <div class="services-process">
            {
                diensten.map((service, i) => (
                    <Card accentBar>
                        <div class="service-step-header">
                            <div class="icon-box icon-box--lg service-icon">
                                <Icon name={service.icon} size={28} />
                            </div>
                            <span class="service-step-number">
                                {String(i + 1).padStart(2, "0")}
                            </span>
                        </div>
                        <h3 class="card-title">{service.title}</h3>
                        <p class="card-desc">{service.description}</p>
                    </Card>
                ))
            }
        </div>
    </div>
</Section>

<style>
    /* ─── Group labels ──────────────────────────────────── */
    .services-group {
        margin-bottom: var(--space-2xl);
    }

    .services-group:last-child {
        margin-bottom: 0;
    }

    .services-group-label {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-family: var(--font-heading);
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-cta);
        margin-bottom: var(--space-xl);
    }

    .services-group-label-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(
            90deg,
            rgba(var(--color-cta-rgb), 0.3),
            rgba(var(--color-cta-rgb), 0.02)
        );
    }

    /* ─── Products: 3-col ───────────────────────────────── */
    .services-products {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    /* ─── Service Process: 4-col ────────────────────────── */
    .services-process {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
    }

    .service-step-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

    .service-step-number {
        font-family: var(--font-heading);
        font-size: 2rem;
        font-weight: 700;
        color: rgba(var(--color-cta-rgb), 0.12);
        line-height: 1;
    }

    .service-icon {
        margin-bottom: 1.25rem;
    }

    .service-step-header .service-icon {
        margin-bottom: 0;
    }

    /* ─── Responsive ────────────────────────────────────── */
    @media (max-width: 1024px) {
        .services-products {
            grid-template-columns: repeat(3, 1fr);
        }
        .services-process {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .services-products {
            grid-template-columns: 1fr;
        }
        .services-process {
            grid-template-columns: 1fr;
        }
    }
</style>
