---
import { SITE } from "../../data/site";
import { HERO_IMAGE } from "../../data/images";
import Section from "../ui/Section.astro";
import Grid from "../ui/Grid.astro";
import Icon from "../ui/Icon.astro";
import IKImage from "../ui/IKImage.astro";
---

<Section id="over-ons">
    <div class="about-grid-wrapper">
        <Grid cols={2} gap="lg">
            <div class="about-visual">
                <div class="about-image-wrapper">
                    <IKImage
                        src={HERO_IMAGE.src}
                        alt={HERO_IMAGE.alt}
                        aspectRatio="4/3"
                        widths={[600, 900, 1200]}
                        sizes="(max-width: 768px) 100vw, 50vw"
                        quality={85}
                        focus="auto"
                        class="about-img"
                    />
                </div>
                <div class="about-float">
                    <span class="float-number">Schüco</span>
                    <span class="float-text">Exclusief Partner</span>
                </div>
            </div>

            <div class="about-content">
                <span class="section-tag">{SITE.overOns.tagline}</span>
                <h2 class="section-title">{SITE.overOns.title}</h2>
                {
                    SITE.overOns.paragraphs.map((p) => (
                        <p class="card-desc about-text">{p}</p>
                    ))
                }

                <div class="about-features">
                    <Grid cols={2} gap="sm">
                        {
                            SITE.overOns.features.map((feature) => (
                                <div class="feature-item">
                                    <div class="icon-box icon-box--sm">
                                        <Icon
                                            name="check"
                                            size={16}
                                            strokeWidth={3}
                                        />
                                    </div>
                                    <span>{feature}</span>
                                </div>
                            ))
                        }
                    </Grid>
                </div>
            </div>
        </Grid>
    </div>
</Section>

<style>
    .about-grid-wrapper :global(.grid) {
        align-items: center;
    }

    .about-visual {
        position: relative;
    }
    .about-image-wrapper {
        aspect-ratio: 4 / 3;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background:
            linear-gradient(
                135deg,
                rgba(var(--color-cta-rgb), 0.1),
                rgba(var(--color-accent-rgb), 0.06)
            ),
            var(--surface-card);
        border: 1px solid var(--border-card);
        border-radius: var(--radius-lg);
    }
    /* IKImage vult de wrapper volledig */
    .about-image-wrapper :global(.about-img) {
        border-radius: 0; /* wrapper bepaalt de radius */
    }
    .about-image-wrapper :global(.ik-img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .about-float {
        position: absolute;
        bottom: -1.5rem;
        right: -1rem;
        padding: 1.25rem 1.75rem;
        text-align: center;
        background: var(--color-cta);
        color: var(--text-on-cta);
        border-radius: var(--radius-md);
        box-shadow:
            var(--shadow-lg),
            0 0 30px rgba(var(--color-cta-rgb), 0.3);
    }
    .float-number {
        display: block;
        font-family: var(--font-heading);
        font-size: clamp(1rem, 3vw, 1.25rem);
        font-weight: 800;
    }
    .float-text {
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--text-on-brand-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .about-text {
        font-size: 1rem;
        line-height: 1.75;
        margin-bottom: 1rem;
    }
    .about-features {
        margin-top: 1.75rem;
    }

    /* Mobile: reposition the float badge so it doesn't overflow */
    @media (max-width: 600px) {
        .about-float {
            right: 1rem;
            bottom: -1rem;
        }
    }
</style>
