---
import { SITE } from "../../data/site";
import Section from "../ui/Section.astro";
import Icon from "../ui/Icon.astro";
---

<Section id="over-ons">
    <div class="about-grid">
        <div class="about-visual">
            <div class="about-image-wrapper">
                <div class="about-image-placeholder">
                    <Icon
                        name="panels-top-left"
                        size={64}
                        strokeWidth={1.5}
                        class="about-placeholder-icon"
                    />
                    <span>{SITE.name}</span>
                </div>
            </div>
            <div class="about-float">
                <span class="float-number">Schüco</span>
                <span class="float-text">Exclusief Partner</span>
            </div>
        </div>

        <div class="about-content">
            <span class="section-tag">{SITE.overOns.tagline}</span>
            <h2 class="section-title">{SITE.overOns.title}</h2>
            {
                SITE.overOns.paragraphs.map((p) => (
                    <p class="card-desc about-text">{p}</p>
                ))
            }

            <div class="about-features">
                {
                    SITE.overOns.features.map((feature) => (
                        <div class="feature-item">
                            <div class="icon-box icon-box--sm">
                                <Icon name="check" size={16} strokeWidth={3} />
                            </div>
                            <span>{feature}</span>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</Section>

<style>
    .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .about-visual {
        position: relative;
    }
    .about-image-wrapper {
        aspect-ratio: 4 / 3;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background:
            linear-gradient(
                135deg,
                rgba(var(--color-cta-rgb), 0.1),
                rgba(var(--color-accent-rgb), 0.06)
            ),
            var(--surface-card);
        border: 1px solid var(--border-card);
        border-radius: var(--radius-lg);
    }
    .about-image-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        color: var(--text-muted);
        font-family: var(--font-heading);
        font-weight: 600;
        font-size: 1.25rem;
    }
    .about-placeholder-icon {
        opacity: 0.3;
    }

    .about-float {
        position: absolute;
        bottom: -1.5rem;
        right: -1rem;
        padding: 1.25rem 1.75rem;
        text-align: center;
        background: var(--color-cta);
        color: var(--text-on-cta);
        border-radius: var(--radius-md);
        box-shadow:
            var(--shadow-lg),
            0 0 30px rgba(var(--color-cta-rgb), 0.3);
    }
    .float-number {
        display: block;
        font-family: var(--font-heading);
        font-size: 1.25rem;
        font-weight: 800;
    }
    .float-text {
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--text-on-brand-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .about-text {
        font-size: 1rem;
        line-height: 1.75;
        margin-bottom: 1rem;
    }
    .about-features {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.875rem;
        margin-top: 1.75rem;
    }

    @media (max-width: 768px) {
        .about-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .about-features {
            grid-template-columns: 1fr;
        }
        .about-float {
            right: 1rem;
            bottom: -1rem;
        }
    }
</style>
