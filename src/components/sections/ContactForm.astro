---
/**
 * ContactForm — Compact CTA section + Modal with React island form
 * The form opens in a modal overlay, saving page space.
 * Contact info is displayed inline in the CTA card.
 */
import { SITE } from "../../data/site";
import Section from "../ui/Section.astro";
import Card from "../ui/Card.astro";
import Icon from "../ui/Icon.astro";
import Modal from "../ui/Modal.astro";
import ContactFormIsland from "../islands/ContactFormIsland";
---

{
    /* ═══════════════════════════════════════════════════════════
   COMPACT CTA SECTION — triggers modal
   ═══════════════════════════════════════════════════════════ */
}
<Section id="contact">
    <div class="cta-card glass-card">
        <div class="cta-glow"></div>
        <div class="cta-content">
            <h2 class="cta-title">Vrijblijvend advies of offerte?</h2>
            <p class="cta-text">
                Neem contact met ons op voor een persoonlijke offerte,
                adviesgesprek of showroomafspraak. Wij denken graag met u mee.
            </p>

            <div class="cta-actions">
                <button
                    class="btn btn-primary btn-lg"
                    data-modal-open="contact-modal"
                    type="button"
                >
                    <Icon name="mail" size={18} />
                    Offerte Aanvragen
                </button>
                <a
                    href={SITE.contact.whatsappHref}
                    class="btn btn-secondary btn-lg"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <Icon name="message-circle" size={18} />
                    WhatsApp
                </a>
                <a
                    href={SITE.contact.phoneHref}
                    class="btn btn-secondary btn-lg"
                >
                    <Icon name="phone" size={18} />
                    Bel Direct
                </a>
            </div>

            <div class="cta-contact-row">
                <div class="cta-contact-item">
                    <Icon name="mail" size={14} class="cta-icon" />
                    <a href={SITE.contact.emailHref}>{SITE.contact.email}</a>
                </div>
                <span class="cta-divider">|</span>
                <div class="cta-contact-item">
                    <Icon name="phone" size={14} class="cta-icon" />
                    <a href={SITE.contact.phoneHref}>{SITE.contact.phone}</a>
                </div>
                <span class="cta-divider">|</span>
                <div class="cta-contact-item">
                    <Icon name="building" size={14} class="cta-icon" />
                    <span>{SITE.legalName} · KvK {SITE.kvk}</span>
                </div>
            </div>
        </div>
    </div>
</Section>

{
    /* ═══════════════════════════════════════════════════════════
   CONTACT MODAL — contains form island
   ═══════════════════════════════════════════════════════════ */
}
<Modal id="contact-modal" title="Offerte aanvragen" size="md">
    <ContactFormIsland client:idle />
</Modal>

<style>
    /* ─── CTA Card ────────────────────────────────────────── */
    .cta-card {
        position: relative;
        padding: 5rem 4rem;
        text-align: center;
        overflow: hidden;
        background: linear-gradient(
            135deg,
            var(--surface-card),
            var(--surface-elevated)
        );
        border: 1px solid var(--border-card);
    }

    .cta-glow {
        position: absolute;
        top: -40%;
        left: 50%;
        transform: translateX(-50%);
        width: 500px;
        height: 500px;
        background: radial-gradient(
            circle,
            rgba(var(--color-cta-rgb), 0.15),
            transparent 55%
        );
        pointer-events: none;
    }

    .cta-content {
        position: relative;
        z-index: 1;
    }

    .cta-title {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        margin-bottom: 1.25rem;
    }

    .cta-text {
        color: var(--text-secondary);
        font-size: 1.0625rem;
        line-height: 1.75;
        max-width: 560px;
        margin: 0 auto 2.5rem;
    }

    .cta-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.875rem;
        margin-bottom: 2.5rem;
    }

    /* ─── Contact Info Row ────────────────────────────────── */
    .cta-contact-row {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.75rem;
        font-size: 0.875rem;
        color: var(--text-muted);
    }

    .cta-contact-item {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
    }

    .cta-contact-item a {
        color: var(--text-secondary);
        text-decoration: none;
        transition: color var(--transition-fast);
    }

    .cta-contact-item a:hover {
        color: var(--color-cta);
    }

    .cta-contact-row :global(.cta-icon) {
        color: var(--color-cta);
        opacity: 0.6;
    }

    .cta-divider {
        opacity: 0.3;
    }

    /* ─── Mobile ──────────────────────────────────────────── */
    @media (max-width: 768px) {
        .cta-card {
            padding: 3rem 1.5rem;
        }
        .cta-actions {
            flex-direction: column;
        }
        .cta-contact-row {
            flex-direction: column;
            gap: 0.5rem;
        }
        .cta-divider {
            display: none;
        }
    }
</style>
