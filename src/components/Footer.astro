---
/**
 * Footer — C&F Bouw
 *
 * Architecture:
 * - Semantic <footer> with aria-label for landmark identification
 * - <nav> wrappers for navigation link lists (a11y)
 * - External links have rel="noopener noreferrer" + sr-only indication
 * - All styles are component-scoped, referencing global design tokens
 * - No client-side JS needed — fully static
 */
import { SITE } from "../data/site";
import { KEURMERKEN } from "../data/keurmerken";
import Grid from "./ui/Grid.astro";
import Icon from "./ui/Icon.astro";
import { ikUrl } from "../lib/imagekit";

const year = new Date().getFullYear();
---

<footer class="footer" id="footer" aria-label="Site footer">
    <div class="container">
        <!-- Brand Row — Logo + Tagline + Badges -->
        <div class="footer-brand">
            <a
                href="/"
                class="footer-logo"
                aria-label={`${SITE.name} — Homepagina`}
            >
                <img
                    src={ikUrl(SITE.logo, {
                        w: 400,
                        h: 267,
                        f: "auto",
                        q: 90,
                    })}
                    alt={`${SITE.name} logo`}
                    width="400"
                    height="267"
                    class="footer-logo-img"
                    loading="lazy"
                />
            </a>
            <div class="footer-brand-text">
                <p class="footer-tagline">
                    Specialist in kunststof kozijnen, deuren en schuifpuien.
                    Schüco kwaliteit, vakkundige montage.
                </p>
                <div class="footer-badges" role="list" aria-label="Keurmerken">
                    {
                        KEURMERKEN.map((k) => (
                            <span class="badge badge--logo" role="listitem" title={k.name}>
                                <img
                                    src={k.logo}
                                    alt={`${k.name} logo`}
                                    class="badge-logo-img"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </span>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- Navigation Grid -->
        <Grid cols={3} gap="lg" class="footer-grid">
            <!-- Column 1: Site Navigation -->
            <div class="footer-col">
                <nav aria-label="Footer navigatie">
                    <h3 class="footer-heading">Navigatie</h3>
                    <ul class="footer-list" role="list">
                        {
                            SITE.nav.map((item) => (
                                <li>
                                    <a href={item.href} class="footer-link">
                                        {item.label}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </nav>
            </div>

            <!-- Column 2: Contact -->
            <div class="footer-col">
                <div class="footer-contact-section">
                    <h3 class="footer-heading">Contact</h3>
                    <ul class="footer-list" role="list">
                        <li class="footer-contact-item">
                            <Icon name="mail" size={16} />
                            <a href={SITE.contact.emailHref} class="footer-link"
                                >{SITE.contact.email}</a
                            >
                        </li>
                        <li class="footer-contact-item">
                            <Icon name="phone" size={16} />
                            <a href={SITE.contact.phoneHref} class="footer-link"
                                >{SITE.contact.phone}</a
                            >
                        </li>
                        <li class="footer-contact-item">
                            <Icon name="message-circle" size={16} />
                            <a
                                href={SITE.contact.whatsappHref}
                                class="footer-link"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                WhatsApp
                                <span class="sr-only"
                                    >(opent in nieuw tabblad)</span
                                >
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Column 3: Project Team -->
            <div class="footer-col">
                <h3 class="footer-heading">Project Team</h3>
                <div class="footer-team-card">
                    <p class="footer-team-role">Fullstack Prompt-engineer</p>
                    <div class="footer-team-name">
                        <span>Jeffrey Lavente</span>
                    </div>
                </div>
            </div>
        </Grid>

        <!-- Bottom Bar — LaventeCare Branding -->
        <div class="footer-bottom">
            <div class="footer-legal">
                <p>{SITE.footer.legalLine}</p>
                <p>{SITE.footer.kvkLine}</p>
            </div>
            <div class="footer-branding">
                <p class="footer-copy">
                    &copy; {year} LaventeCare. All rights reserved.
                </p>
                <p class="footer-powered">
                    Powered by <a
                        href="https://www.laventecare.nl"
                        class="footer-shimmer-link"
                        target="_blank"
                        rel="noopener noreferrer"
                    >LaventeCare AuthSystem<span class="sr-only"> (opent in nieuw tabblad)</span></a>
                </p>
            </div>
        </div>
    </div>
</footer>

<style>
    .footer {
        background: var(--footer-bg);
        color: var(--footer-text);
        padding: var(--space-3xl) 0 0;
        position: relative;
        border-top: none; /* replaced by ::before gradient */
    }

    /* Light mode: a gradient bridge from the warm contact bg into footer blue */
    .footer::before {
        content: '';
        position: absolute;
        top: -48px;
        left: 0;
        right: 0;
        height: 48px;
        background: linear-gradient(
            to bottom,
            transparent,
            rgba(var(--color-primary-rgb), 0.18)
        );
        pointer-events: none;
        z-index: 0;
    }

    /* Dark mode: suppress the bridge — dark-to-darker transition needs no help */
    :global([data-theme="dark"]) .footer::before {
        display: none;
    }

    /* Dark mode: restore a clean separator border */
    :global([data-theme="dark"]) .footer {
        border-top: 1px solid var(--footer-border);
    }

    .footer-grid {
        padding-bottom: var(--space-2xl);
    }

    /* ── Brand Row ─────────────────────────────────────── */

    .footer-brand {
        display: flex;
        align-items: center;
        gap: var(--space-2xl);
        padding-bottom: var(--space-2xl);
        margin-bottom: var(--space-xl);
        border-bottom: 1px solid var(--footer-border);
    }

    .footer-logo {
        flex-shrink: 0;
        display: block;
        text-decoration: none;
    }

    .footer-logo-img {
        /* width controlled by mobile-first responsive rules below */
        max-width: 100%;
        height: auto;
        object-fit: contain;
        transition: opacity var(--transition-fast);
    }

    .footer-logo:hover .footer-logo-img {
        opacity: 0.85;
    }

    .footer-brand-text {
        flex: 1;
    }

    .footer-tagline {
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--footer-muted);
        margin-bottom: var(--space-md);
        max-width: 360px;
    }

    .footer-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.75rem;
        background: var(--footer-badge-bg);
        border: 1px solid var(--footer-badge-border);
        border-radius: var(--radius-full);
        font-family: var(--font-heading);
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--footer-badge-text);
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .badge--logo {
        padding: 0.3rem 0.625rem;
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.15);
        border-radius: var(--radius-sm);
    }

    .badge-logo-img {
        height: 24px;
        width: auto;
        object-fit: contain;
        filter: brightness(0) invert(1);
        opacity: 0.85;
    }

    /* ── Columns ────────────────────────────────────────── */

    .footer-heading {
        font-family: var(--font-heading);
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--footer-heading);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: var(--space-lg);
    }

    .footer-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
    }

    .footer-link {
        color: var(--footer-muted);
        font-size: 0.9375rem;
        text-decoration: none;
        transition: color var(--transition-fast);
    }

    .footer-link:hover {
        color: var(--footer-heading);
    }

    .footer-contact-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--footer-muted);
    }

    .footer-contact-item :global(svg) {
        flex-shrink: 0;
        opacity: 0.6;
    }

    /* ── Bottom Bar ─────────────────────────────────────── */

    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-lg) 0;
        border-top: 1px solid var(--footer-border);
    }

    .footer-legal p {
        font-size: 0.8125rem;
        color: var(--footer-dim);
        line-height: 1.5;
    }

    .footer-branding {
        text-align: right;
    }

    .footer-copy {
        font-size: 0.8125rem;
        color: var(--footer-dim);
    }

    .footer-powered {
        font-size: 0.8125rem;
        color: var(--footer-dim);
        margin-top: 0.25rem;
    }

    /* ── Shimmer Link — Signature Element ───────────────── */

    .footer-shimmer-link {
        font-weight: 600;
        background: linear-gradient(
            to right,
            #ffffff,
            #a5d8f0,
            #ffffff
        );
        background-size: 200% auto;
        animation: shimmer 3s linear infinite;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        transition: opacity var(--transition-fast);
        text-decoration: none;
    }

    :global([data-theme="dark"]) .footer-shimmer-link {
        background: linear-gradient(
            to right,
            #2A85BC,
            #4ecdc4,
            #2A85BC
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        background-clip: text;
    }

    .footer-shimmer-link:hover {
        opacity: 0.8;
        color: transparent;
    }

    /* ── Project Team Card ──────────────────────────────── */

    .footer-team-card {
        padding: var(--space-md);
        border-radius: var(--radius-md);
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid var(--footer-border);
    }

    .footer-team-role {
        font-size: 0.75rem;
        color: var(--footer-dim);
        margin-bottom: 0.5rem;
    }

    .footer-team-name {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        color: var(--footer-heading);
    }

    .footer-heart {
        flex-shrink: 0;
    }

    /* ── Responsive — Mobile-First ────────────────────────── */

    /* Mobile base: brand row stacks vertically */
    .footer-brand {
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-lg);
    }
    .footer-logo-img {
        width: clamp(200px, 40vw, 280px); /* fluid: smaller on mobile */
    }
    .footer-bottom {
        flex-direction: column;
        gap: 0.75rem;
        text-align: center;
    }
    .footer-legal {
        text-align: center;
    }
    .footer-branding {
        text-align: center;
    }

    /* Desktop (>=769px): switch brand row back to horizontal */
    @media (min-width: 769px) {
        .footer-brand {
            flex-direction: row;
            align-items: center;
            gap: var(--space-2xl);
        }
        .footer-logo-img {
            width: clamp(280px, 30vw, 380px); /* desktop: wider logo */
        }
        .footer-bottom {
            flex-direction: row;
            gap: 0;
            text-align: left;
        }
        .footer-legal {
            text-align: left;
        }
        .footer-branding {
            text-align: right;
        }
    }
</style>
