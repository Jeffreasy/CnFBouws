---
import { SITE } from "../data/site";
import { KEURMERKEN } from "../data/keurmerken";
import Icon from "./ui/Icon.astro";
import { ikUrl } from "../lib/imagekit";

const year = new Date().getFullYear();
---

<footer class="footer" id="footer">
    <div class="container">
        <!-- Brand Row — Logo prominent, full width -->
        <div class="footer-brand">
            <div class="footer-logo">
                <img
                    src={ikUrl(SITE.logo, {
                        w: 400,
                        h: 267,
                        f: "auto",
                        q: 90,
                    })}
                    alt={`${SITE.name} logo`}
                    width="400"
                    height="267"
                    class="footer-logo-img"
                    loading="lazy"
                />
            </div>
            <div class="footer-brand-text">
                <p class="footer-tagline">
                    Specialist in kunststof kozijnen, deuren en schuifpuien.
                    Schüco kwaliteit, vakkundige montage.
                </p>
                <div class="footer-badges">
                    {
                        KEURMERKEN.map((k) => (
                            <span class="badge" title={k.name}>
                                {k.abbreviation}
                            </span>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- Navigation Grid -->
        <div class="footer-grid">
            <div class="footer-col">
                <h4 class="footer-heading">Navigatie</h4>
                <ul class="footer-list" role="list">
                    {
                        SITE.nav.map((item) => (
                            <li>
                                <a href={item.href} class="footer-link">
                                    {item.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Column 3: Diensten -->
            <div class="footer-col">
                <h4 class="footer-heading">Diensten</h4>
                <ul class="footer-list" role="list">
                    <li>
                        <a href="#diensten" class="footer-link"
                            >Advies op maat</a
                        >
                    </li>
                    <li>
                        <a href="#diensten" class="footer-link"
                            >Inmeten op locatie</a
                        >
                    </li>
                    <li>
                        <a href="#diensten" class="footer-link"
                            >Kunststof kozijnen</a
                        >
                    </li>
                    <li>
                        <a href="#diensten" class="footer-link"
                            >Professionele montage</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Column 4: Contact -->
            <div class="footer-col">
                <h4 class="footer-heading">Contact</h4>
                <ul class="footer-list" role="list">
                    <li class="footer-contact-item">
                        <Icon name="mail" size={16} />
                        <a href={SITE.contact.emailHref} class="footer-link"
                            >{SITE.contact.email}</a
                        >
                    </li>
                    <li class="footer-contact-item">
                        <Icon name="phone" size={16} />
                        <a href={SITE.contact.phoneHref} class="footer-link"
                            >{SITE.contact.phone}</a
                        >
                    </li>
                    <li class="footer-contact-item">
                        <Icon name="message-circle" size={16} />
                        <a
                            href={SITE.contact.whatsappHref}
                            class="footer-link"
                            target="_blank"
                            rel="noopener noreferrer">WhatsApp</a
                        >
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div class="footer-bottom">
            <div class="footer-legal">
                <p>{SITE.footer.legalLine}</p>
                <p>{SITE.footer.kvkLine}</p>
            </div>
            <p class="footer-copy">
                &copy; {year}
                {SITE.name}. Alle rechten voorbehouden.
            </p>
        </div>
    </div>
</footer>

<style>
    .footer {
        background: var(--footer-bg);
        color: var(--footer-text);
        padding: var(--space-3xl) 0 0;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-2xl);
        padding-bottom: var(--space-2xl);
    }

    /* ─── Brand Row — Logo + Text side by side ─────────── */
    .footer-brand {
        display: flex;
        align-items: center;
        gap: var(--space-2xl);
        padding-bottom: var(--space-2xl);
        margin-bottom: var(--space-xl);
        border-bottom: 1px solid var(--footer-border);
    }

    .footer-logo {
        flex-shrink: 0;
    }

    .footer-logo-img {
        width: 380px;
        max-width: 100%;
        height: auto;
        object-fit: contain;
    }

    .footer-brand-text {
        flex: 1;
    }

    .footer-tagline {
        font-size: 0.9375rem;
        line-height: 1.65;
        color: var(--footer-muted);
        margin-bottom: var(--space-md);
        max-width: 360px;
    }

    .footer-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.75rem;
        background: var(--footer-badge-bg);
        border: 1px solid var(--footer-badge-border);
        border-radius: var(--radius-full);
        font-family: var(--font-heading);
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--footer-badge-text);
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    /* ─── Columns ───────────────────────────────────────── */
    .footer-heading {
        font-family: var(--font-heading);
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--footer-heading);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: var(--space-lg);
    }

    .footer-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
    }

    .footer-link {
        color: var(--footer-muted);
        font-size: 0.9375rem;
        text-decoration: none;
        transition: color var(--transition-fast);
    }

    .footer-link:hover {
        color: var(--footer-heading);
    }

    .footer-contact-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--footer-muted);
    }

    .footer-contact-item :global(svg) {
        flex-shrink: 0;
        opacity: 0.6;
    }

    /* ─── Bottom Bar ────────────────────────────────────── */
    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-lg) 0;
        border-top: 1px solid var(--footer-border);
    }

    .footer-legal p {
        font-size: 0.8125rem;
        color: var(--footer-dim);
        line-height: 1.5;
    }

    .footer-copy {
        font-size: 0.8125rem;
        color: var(--footer-dim);
    }

    /* ─── Responsive ────────────────────────────────────── */
    @media (max-width: 768px) {
        .footer-brand {
            flex-direction: column;
            align-items: flex-start;
            gap: var(--space-lg);
        }
        .footer-logo-img {
            width: 280px;
        }
        .footer-grid {
            grid-template-columns: 1fr;
            gap: var(--space-xl);
        }

        .footer-bottom {
            flex-direction: column;
            gap: 0.75rem;
            text-align: center;
        }

        .footer-legal {
            text-align: center;
        }
    }

    @media (min-width: 769px) and (max-width: 1024px) {
        .footer-grid {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>
