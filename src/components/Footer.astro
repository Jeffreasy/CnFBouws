---
import { SITE } from "../data/site";
import { KEURMERKEN } from "../data/keurmerken";

const year = new Date().getFullYear();
---

<footer class="footer" id="footer">
    <div class="container">
        <!-- Main Footer Grid -->
        <div class="footer-grid">
            <!-- Column 1: Brand -->
            <div class="footer-brand">
                <div class="footer-logo">
                    <span class="footer-logo-c">C</span><span
                        class="footer-logo-amp">&</span
                    ><span class="footer-logo-f">F</span>
                    <span class="footer-logo-name">Bouw</span>
                </div>
                <p class="footer-tagline">
                    Specialist in kunststof kozijnen, deuren en schuifpuien.
                    Schüco kwaliteit, vakkundige montage.
                </p>
                <!-- Keurmerken Badges -->
                <div class="footer-badges">
                    {
                        KEURMERKEN.map((k) => (
                            <span class="badge" title={k.name}>
                                {k.abbreviation}
                            </span>
                        ))
                    }
                </div>
            </div>

            <!-- Column 2: Navigation -->
            <div class="footer-col">
                <h4 class="footer-heading">Navigatie</h4>
                <ul class="footer-list" role="list">
                    {
                        SITE.nav.map((item) => (
                            <li>
                                <a href={item.href} class="footer-link">
                                    {item.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Column 3: Diensten -->
            <div class="footer-col">
                <h4 class="footer-heading">Diensten</h4>
                <ul class="footer-list" role="list">
                    <li>
                        <a href="#diensten" class="footer-link"
                            >Advies op maat</a>
                    </li>
                    <li>
                        <a href="#diensten" class="footer-link"
                            >Inmeten op locatie</a>
                    </li>
                    <li>
                        <a href="#diensten" class="footer-link"
                            >Kunststof kozijnen</a>
                    </li>
                    <li>
                        <a href="#diensten" class="footer-link"
                            >Professionele montage</a>
                    </li>
                </ul>
            </div>

            <!-- Column 4: Contact -->
            <div class="footer-col">
                <h4 class="footer-heading">Contact</h4>
                <ul class="footer-list" role="list">
                    <li class="footer-contact-item">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path
                                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                            ></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                        <a href={SITE.contact.emailHref} class="footer-link"
                            >{SITE.contact.email}</a
                        >
                    </li>
                    <li class="footer-contact-item">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path
                                d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
                            ></path>
                        </svg>
                        <a href={SITE.contact.phoneHref} class="footer-link"
                            >{SITE.contact.phone}</a
                        >
                    </li>
                    <li class="footer-contact-item">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path
                                d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"
                            ></path>
                        </svg>
                        <a
                            href={SITE.contact.whatsappHref}
                            class="footer-link"
                            target="_blank"
                            rel="noopener noreferrer">WhatsApp</a
                        >
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div class="footer-bottom">
            <div class="footer-legal">
                <p>{SITE.footer.legalLine}</p>
                <p>{SITE.footer.kvkLine}</p>
            </div>
            <p class="footer-copy">
                &copy; {year}
                {SITE.name}. Alle rechten voorbehouden.
            </p>
        </div>
    </div>
</footer>

<style>
    .footer {
        background: var(--color-primary);
        color: #cbd5e1;
        padding: var(--space-3xl) 0 0;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1.5fr;
        gap: var(--space-2xl);
        padding-bottom: var(--space-2xl);
    }

    /* ─── Brand Column ──────────────────────────────────── */
    .footer-logo {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        font-family: "Lexend", system-ui, sans-serif;
        font-weight: 800;
        font-size: 1.75rem;
        color: #ffffff;
        margin-bottom: var(--space-md);
    }

    .footer-logo-amp {
        color: var(--color-cta);
        font-weight: 700;
        margin: 0 0.1rem;
    }

    .footer-logo-name {
        font-weight: 600;
        margin-left: 0.25rem;
    }

    .footer-tagline {
        font-size: 0.9375rem;
        line-height: 1.65;
        color: #94a3b8;
        margin-bottom: var(--space-lg);
        max-width: 300px;
    }

    .footer-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.75rem;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: var(--radius-full);
        font-family: "Lexend", system-ui, sans-serif;
        font-size: 0.6875rem;
        font-weight: 600;
        color: #e2e8f0;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    /* ─── Columns ───────────────────────────────────────── */
    .footer-heading {
        font-family: "Lexend", system-ui, sans-serif;
        font-size: 0.875rem;
        font-weight: 700;
        color: #ffffff;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: var(--space-lg);
    }

    .footer-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
    }

    .footer-link {
        color: #94a3b8;
        font-size: 0.9375rem;
        text-decoration: none;
        transition: color var(--transition-fast);
    }

    .footer-link:hover {
        color: #ffffff;
    }

    .footer-contact-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #94a3b8;
    }

    .footer-contact-item svg {
        flex-shrink: 0;
        opacity: 0.6;
    }

    /* ─── Bottom Bar ────────────────────────────────────── */
    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-lg) 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .footer-legal p {
        font-size: 0.8125rem;
        color: #64748b;
        line-height: 1.5;
    }

    .footer-copy {
        font-size: 0.8125rem;
        color: #64748b;
    }

    /* ─── Responsive ────────────────────────────────────── */
    @media (max-width: 768px) {
        .footer-grid {
            grid-template-columns: 1fr;
            gap: var(--space-xl);
        }

        .footer-bottom {
            flex-direction: column;
            gap: 0.75rem;
            text-align: center;
        }

        .footer-legal {
            text-align: center;
        }
    }

    @media (min-width: 769px) and (max-width: 1024px) {
        .footer-grid {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>
