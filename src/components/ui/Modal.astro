---
/**
 * Modal — Reusable glass modal overlay
 *
 * Usage: trigger with data-modal-open="modal-id" on any button/anchor
 *
 * Props:
 *   id       — unique identifier (used by trigger buttons)
 *   title    — modal header title
 *   size     — "sm" | "md" | "lg" (default: "md")
 *
 * View Transitions:
 *   Script uses astro:page-load for VT compatibility.
 *   Cleanup via astro:before-swap prevents listener leaks.
 */
interface Props {
    id: string;
    title?: string;
    size?: "sm" | "md" | "lg";
}

const { id, title, size = "md" } = Astro.props;
---

<div class={`modal-backdrop`} id={`${id}-backdrop`} data-modal-id={id}>
    <div
        class={`modal-panel modal-panel--${size}`}
        role="dialog"
        aria-modal="true"
        aria-labelledby={title ? `${id}-title` : undefined}
    >
        {/* ─── Header ────────────────────────────────────── */}
        <div class="modal-header">
            {
                title && (
                    <h3 class="modal-title" id={`${id}-title`}>
                        {title}
                    </h3>
                )
            }
            <button
                class="modal-close"
                data-modal-close={id}
                aria-label="Sluiten"
                type="button"
            >
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>

        {/* ─── Body (slot) ───────────────────────────────── */}
        <div class="modal-body" role="document">
            <slot />
        </div>
    </div>
</div>

<style>
    /* ═══════════════════════════════════════════════════════════
       MODAL BACKDROP
       ═══════════════════════════════════════════════════════════ */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: var(--z-modal);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        opacity: 0;
        transition: opacity 0.25s ease;
    }

    .modal-backdrop.open {
        display: flex;
        opacity: 1;
    }

    /* Smooth fade-out: opacity → 0 before display:none */
    .modal-backdrop.is-closing {
        opacity: 0;
        pointer-events: none;
    }

    .modal-backdrop.is-closing .modal-panel {
        transform: translateY(8px) scale(0.99);
    }

    /* ═══════════════════════════════════════════════════════════
       MODAL PANEL
       ═══════════════════════════════════════════════════════════ */
    .modal-panel {
        position: relative;
        width: 100%;
        max-height: calc(100vh - 3rem);
        overflow-y: auto;
        overscroll-behavior: contain;       /* prevent scroll-through to page */
        -webkit-overflow-scrolling: touch;  /* momentum scrolling on iOS */
        background: linear-gradient(
            135deg,
            var(--surface-card),
            var(--surface-elevated)
        );
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--border-glass);
        border-radius: var(--radius-lg);
        box-shadow:
            var(--shadow-xl),
            inset 0 1px 0 rgba(255, 255, 255, 0.06);
        transform: translateY(16px) scale(0.98);
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .modal-backdrop.open .modal-panel {
        transform: translateY(0) scale(1);
    }

    /* Sizes */
    .modal-panel--sm {
        max-width: 420px;
    }
    .modal-panel--md {
        max-width: 560px;
    }
    .modal-panel--lg {
        max-width: 720px;
    }

    /* ═══════════════════════════════════════════════════════════
       HEADER
       ═══════════════════════════════════════════════════════════ */
    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem 2rem;
        border-bottom: 1px solid var(--border-subtle);
    }

    .modal-title {
        font-size: clamp(1.0625rem, 2.5vw, 1.25rem);
        font-weight: 700;
        color: var(--text-heading);
        margin: 0;
    }

    .modal-close {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-sm);
        background: transparent;
        color: var(--text-secondary);
        cursor: pointer;
        transition:
            color var(--transition-fast),
            background var(--transition-fast),
            border-color var(--transition-fast);
    }

    .modal-close:hover {
        color: var(--color-cta);
        background: rgba(var(--color-cta-rgb), 0.08);
        border-color: rgba(var(--color-cta-rgb), 0.25);
    }

    /* ─── BODY ─────────────────────────────────────────────── */
    .modal-body {
        padding: clamp(1.25rem, 3vw, 2rem);
    }

    /* ─── Mobile ─────────────────────────────────────────── */
    @media (max-width: 768px) {
        .modal-backdrop {
            padding: 0;
            align-items: flex-end;
        }
        .modal-panel {
            /* Full-width bottom-sheet, never wider than viewport */
            width: 100%;
            max-width: 100% !important;
            max-height: 92svh;   /* svh = small viewport height — accounts for mobile browser chrome */
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
            /* iOS home bar safe area: padding-bottom so submit is never hidden */
            padding-bottom: env(safe-area-inset-bottom, 0px);
        }
        .modal-header {
            padding: 1.25rem 1.25rem 1.125rem;
            position: sticky;
            top: 0;
            background: var(--surface-card); /* header stays visible while scrolling */
            z-index: 1;
        }
        .modal-body {
            padding: 1.25rem;
        }
    }
</style>

<script>
    /**
     * Modal Controller — View Transitions Compatible
     *
     * Uses astro:page-load for initialization and
     * astro:before-swap for cleanup to prevent listener leaks.
     */

    let modalCleanupFns: Array<() => void> = [];

    function closeModal(modalId: string | null): void {
        if (!modalId) return;
        const backdrop = document.getElementById(`${modalId}-backdrop`);
        if (!backdrop || !backdrop.classList.contains("open")) return;

        // Return focus to trigger immediately (before visual close)
        const trigger = document.querySelector<HTMLElement>(
            `[data-modal-open="${modalId}"]`,
        );

        // Fade-out animation: add is-closing, wait for transition, then hide
        backdrop.classList.add("is-closing");
        setTimeout(() => {
            backdrop.classList.remove("open", "is-closing");
            document.documentElement.style.overflow = "";
            trigger?.focus();
            // Notify islands so they can reset state
            document.dispatchEvent(
                new CustomEvent("modal:closed", { detail: { id: modalId } })
            );
        }, 260); // slightly > transition 0.25s to ensure animation completes
    }

    function initModals(): void {
        // ── Open triggers ──
        const openTriggers =
            document.querySelectorAll<HTMLElement>("[data-modal-open]");
        openTriggers.forEach((trigger) => {
            const handler = (e: Event): void => {
                e.preventDefault();
                const modalId = trigger.getAttribute("data-modal-open");
                if (!modalId) return;

                // Close mobile menu if open (interop with Navbar)
                const navToggle = document.getElementById(
                    "nav-toggle",
                ) as HTMLButtonElement | null;
                if (navToggle?.getAttribute("aria-expanded") === "true") {
                    navToggle.click();
                }

                const backdrop = document.getElementById(`${modalId}-backdrop`);
                if (!backdrop) return;
                backdrop.classList.add("open");
                document.documentElement.style.overflow = "hidden";

                // Focus first focusable element
                const focusable = backdrop.querySelector<HTMLElement>(
                    "input:not([hidden]), select:not([hidden]), textarea:not([hidden]), button:not(.modal-close):not([hidden]), a[href]:not([hidden])",
                );
                setTimeout(() => focusable?.focus(), 100);
            };
            trigger.addEventListener("click", handler);
            modalCleanupFns.push(() =>
                trigger.removeEventListener("click", handler),
            );
        });

        // ── Close button triggers ──
        const closeTriggers =
            document.querySelectorAll<HTMLElement>("[data-modal-close]");
        closeTriggers.forEach((btn) => {
            const handler = (): void => {
                const modalId = btn.getAttribute("data-modal-close");
                closeModal(modalId);
            };
            btn.addEventListener("click", handler);
            modalCleanupFns.push(() =>
                btn.removeEventListener("click", handler),
            );
        });

        // ── Backdrop click closes ──
        const backdrops =
            document.querySelectorAll<HTMLElement>(".modal-backdrop");
        backdrops.forEach((backdrop) => {
            const handler = (e: Event): void => {
                if (e.target === backdrop) {
                    const modalId = backdrop.getAttribute("data-modal-id");
                    closeModal(modalId);
                }
            };
            backdrop.addEventListener("click", handler);
            modalCleanupFns.push(() =>
                backdrop.removeEventListener("click", handler),
            );
        });

        // ── Escape key + Focus trap ──
        const onKeydown = (e: KeyboardEvent): void => {
            // Escape closes open modal
            if (e.key === "Escape") {
                const openBackdrop = document.querySelector(
                    ".modal-backdrop.open",
                );
                if (openBackdrop) {
                    const modalId = openBackdrop.getAttribute("data-modal-id");
                    closeModal(modalId);
                }
                return;
            }

            // Focus trap on Tab
            if (e.key !== "Tab") return;
            const openBackdrop = document.querySelector(".modal-backdrop.open");
            if (!openBackdrop) return;

            const focusable = openBackdrop.querySelectorAll<HTMLElement>(
                'a[href]:not([hidden]), button:not([disabled]):not([hidden]), input:not([disabled]):not([hidden]):not([tabindex="-1"]), select:not([disabled]):not([hidden]), textarea:not([disabled]):not([hidden]), [tabindex]:not([tabindex="-1"]):not([hidden])',
            );
            if (focusable.length === 0) return;

            const first = focusable[0];
            const last = focusable[focusable.length - 1];

            if (e.shiftKey) {
                if (document.activeElement === first) {
                    e.preventDefault();
                    last.focus();
                }
            } else {
                if (document.activeElement === last) {
                    e.preventDefault();
                    first.focus();
                }
            }
        };
        document.addEventListener("keydown", onKeydown);
        modalCleanupFns.push(() =>
            document.removeEventListener("keydown", onKeydown),
        );
    }

    function cleanupModals(): void {
        // Close any open modals before swap
        const openModal = document.querySelector(".modal-backdrop.open");
        if (openModal) {
            const modalId = openModal.getAttribute("data-modal-id");
            closeModal(modalId);
        }

        // Remove all registered event listeners
        modalCleanupFns.forEach((fn) => fn());
        modalCleanupFns = [];
    }

    // ── View Transitions lifecycle ──
    document.addEventListener("astro:page-load", initModals);
    document.addEventListener("astro:before-swap", cleanupModals);
</script>
