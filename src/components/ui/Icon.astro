---
/**
 * Reusable SVG Icon component.
 * Uses centralized icon paths from `src/data/icons.ts`.
 *
 * @example <Icon name="mail" size={18} />
 * @example <Icon name="check" size={14} strokeWidth={3} />
 */
interface Props {
    name: string;
    size?: number;
    strokeWidth?: number;
    class?: string;
}

const { name, size = 24, strokeWidth = 2, class: className = "" } = Astro.props;

import { ICONS } from "../../data/icons";
const path = ICONS[name] || "";
---

<svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
>
    <Fragment set:html={path} />
</svg>
