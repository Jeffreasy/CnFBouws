---
/**
 * IKImage — Optimized image component using ImageKit CDN
 *
 * Features:
 *   - Automatic format negotiation (WebP/AVIF)
 *   - Responsive srcset generation
 *   - Low-quality placeholder (LQIP) real blur-up via CSS background + onload
 *   - Lazy loading by default
 *   - Proper alt text enforcement
 *
 * @example
 * <IKImage src="/hero/banner.jpg" alt="C&F Bouw werkplaats" width={1200} />
 * <IKImage src="/producten/kozijn.jpg" alt="Kunststof kozijn" sizes="(max-width: 768px) 100vw, 50vw" />
 * <IKImage src="/logo.png" alt="Logo" noLqip />
 */
import { ikUrl, ikSrcSet, type IKTransform } from "../../lib/imagekit";

interface Props {
    /** Image path on ImageKit (e.g. "/hero/banner.jpg") */
    src: string;
    /** Alt text (required for accessibility) */
    alt: string;
    /** Display width */
    width?: number;
    /** Display height */
    height?: number;
    /** Responsive sizes attribute */
    sizes?: string;
    /** Srcset widths */
    widths?: number[];
    /** ImageKit quality 1-100 */
    quality?: number;
    /** CSS class */
    class?: string;
    /** Loading strategy */
    loading?: "lazy" | "eager";
    /** Fetch priority optimization */
    fetchpriority?: "high" | "low" | "auto";
    /** Object-fit CSS value */
    fit?: "cover" | "contain" | "fill" | "none";
    /** Aspect ratio (e.g. "16/9", "4/3") */
    aspectRatio?: string;
    /** Focus area for smart cropping */
    focus?: "auto" | "face" | "center";
    /** Additional transforms */
    transforms?: IKTransform;
    /** Disable LQIP blur-up (useful for small icons or logos) */
    noLqip?: boolean;
}

const {
    src,
    alt,
    width,
    height,
    sizes = "(max-width: 768px) 100vw, (max-width: 1200px) 80vw, 1200px",
    widths = [400, 800, 1200, 1600],
    quality = 80,
    class: className = "",
    loading = "lazy",
    fetchpriority,
    fit = "cover",
    aspectRatio,
    focus,
    transforms = {},
    noLqip = false,
} = Astro.props;

const baseTransforms: IKTransform = {
    f: "auto",
    q: quality,
    ...(focus ? { fo: focus } : {}),
    ...transforms,
};

const mainSrc = ikUrl(src, { ...baseTransforms, w: width });
const srcset = ikSrcSet(src, widths, baseTransforms);

// LQIP: 20px wide, quality 20, ImageKit blur (bl-10) — renders in ~1-3KB
// Used as CSS background-image on the wrapper so it shows instantly before
// the real <img> loads. When the real img finishes loading, opacity fades to 1.
const lqipSrc = noLqip
    ? undefined
    : ikUrl(src, { w: 20, q: 20, bl: 10, f: "auto" });

const imgStyle = [
    fit && `object-fit: ${fit}`,
    aspectRatio && `aspect-ratio: ${aspectRatio}`,
]
    .filter(Boolean)
    .join("; ");

const resolvedFetchPriority =
    fetchpriority || (loading === "eager" ? "high" : "auto");

// Unique per-instance ID so each img can be targeted by its own onload script.
// Math.random is fine here — this only runs at build/SSR time.
const uid = `ik-${Math.random().toString(36).slice(2, 9)}`;

const wrapperStyle = [
    aspectRatio ? `aspect-ratio: ${aspectRatio}` : "",
    lqipSrc
        ? `background-image: url('${lqipSrc}'); background-size: cover; background-position: center;`
        : "",
]
    .filter(Boolean)
    .join("; ");
---

<div
    class:list={["ik-image", className]}
    style={wrapperStyle || undefined}
>
    <img
        id={uid}
        src={mainSrc}
        srcset={srcset}
        sizes={sizes}
        alt={alt}
        width={width}
        height={height}
        loading={loading}
        fetchpriority={resolvedFetchPriority}
        decoding="async"
        style={imgStyle || undefined}
        class:list={["ik-img", lqipSrc ? "ik-img--lqip" : ""]}
    />
</div>

{/* Blur-up handled centrally by BaseLayout's initImageReveal() via .ik-img--lqip class */}

<style>
    .ik-image {
        position: relative;
        overflow: hidden;
        border-radius: var(--radius-lg);
    }

    .ik-img {
        display: block;
        width: 100%;
        height: 100%;
    }

    /* LQIP blur-up: img starts invisible, fades in once loaded */
    .ik-img--lqip {
        opacity: 0;
        transition: opacity 0.45s ease;
    }

    .ik-img--lqip.is-loaded {
        opacity: 1;
    }
</style>
