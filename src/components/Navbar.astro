---
/**
 * Navbar — C&F Bouw
 *
 * Architecture:
 * - Semantic <header> landmark with <nav> inside
 * - Server-side active states via Astro.url.pathname (for multi-page routes)
 * - IntersectionObserver for hash-based section highlighting (single-page)
 * - View Transitions compatible: astro:page-load / astro:before-swap
 * - Mobile menu with ARIA dialog pattern + focus trap
 * - Z-indexes via global design tokens (--z-*)
 */
import { SITE } from "../data/site";
import Icon from "./ui/Icon.astro";
import { ikUrl } from "../lib/imagekit";

/**
 * Active state for nav items:
 * - Hash links (#diensten) → handled client-side via IntersectionObserver
 * - Path links (/about) → would be matched server-side when multi-page routes exist
 *
 * Note: Astro.url.pathname is avoided here because the homepage is prerendered
 * (prerender = true) and accessing it triggers an Astro.request.headers warning.
 * When adding multi-page routes, switch to: const currentPath = Astro.url.pathname;
 */
function isActive(href: string): boolean {
  if (href.startsWith("#")) return false; // Handled client-side
  return href === "/"; // Only root matches on this single-page site
}
---

<header class="navbar" id="main-nav">
  <div class="nav-container">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label={`${SITE.name} — Homepagina`}>
      <img
        src={ikUrl(SITE.logo, { w: 400, h: 267, f: "auto", q: 90 })}
        alt={`${SITE.name} logo`}
        width="400"
        height="267"
        class="logo-img"
        loading="eager"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav aria-label="Hoofdnavigatie">
      <ul class="nav-links" role="list">
        {
          SITE.nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={["nav-link", { active: isActive(item.href) }]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- CTA + Theme Toggle + Hamburger -->
    <div class="nav-actions">
      <button
        type="button"
        data-modal-open="contact-modal"
        class="btn btn-primary nav-cta"
      >
        {SITE.cta.primary.label}
      </button>

      <button
        class="theme-toggle"
        id="theme-toggle"
        type="button"
        aria-label="Thema wisselen"
      >
        <svg
          class="theme-icon theme-icon--sun"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg
          class="theme-icon theme-icon--moon"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
        </svg>
      </button>

      <button
        class="nav-toggle"
        id="nav-toggle"
        type="button"
        aria-label="Menu openen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="toggle-bar"></span>
        <span class="toggle-bar"></span>
        <span class="toggle-bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu (ARIA dialog pattern) -->
  <div
    class="mobile-menu"
    id="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label="Mobiel navigatiemenu"
    hidden
  >
    <nav aria-label="Mobiele navigatie">
      <ul class="mobile-links" role="list">
        {
          SITE.nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={["mobile-link", { active: isActive(item.href) }]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="mobile-cta">
      <button
        type="button"
        data-modal-open="contact-modal"
        class="btn btn-primary btn-lg mobile-btn"
      >
        {SITE.cta.primary.label}
      </button>
      <a
        href={SITE.contact.phoneHref}
        class="btn btn-secondary btn-lg mobile-btn"
      >
        <Icon name="phone" size={18} />
        Bel Direct
      </a>
    </div>
  </div>

  <!-- Mobile Backdrop -->
  <div class="nav-backdrop" id="nav-backdrop" aria-hidden="true"></div>
</header>

<style>
  /* ═══════════════════════════════════════════════════════════
     NAVBAR — Component-Scoped Styles
     Z-indexes via global tokens (--z-*)
     ═══════════════════════════════════════════════════════════ */

  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-navbar);
    background: var(--surface-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-subtle);
    overflow: visible;
    transition:
      background var(--transition-normal),
      box-shadow var(--transition-normal),
      border-color var(--transition-normal);
  }

  .navbar.scrolled {
    box-shadow: var(--shadow-md);
  }

  .nav-container {
    max-width: 1200px;
    margin-inline: auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    height: 72px;
    gap: 1rem;
    overflow: visible;
  }

  /* ── Logo ─────────────────────────────────────────────── */

  .nav-logo {
    margin-right: auto;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    align-self: center;
    overflow: visible;
    text-decoration: none;
    cursor: pointer;
    z-index: 10;
  }

  .logo-img {
    width: clamp(200px, 30vw, 400px);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.15));
    transform: translateY(16px);
    transition:
      width var(--transition-normal),
      transform var(--transition-fast);
  }

  .nav-logo:hover .logo-img {
    opacity: 0.85;
  }

  /* ── Desktop Nav Links ───────────────────────────────── */

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .nav-link {
    display: block;
    padding: 0.5rem 1rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    position: relative;
    transition:
      color var(--transition-fast),
      background var(--transition-fast);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--color-cta);
    border-radius: 1px;
    transform: translateX(-50%);
    transition: width var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-cta);
    background: rgba(var(--color-cta-rgb), 0.06);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 60%;
  }

  .nav-link.active {
    color: var(--color-cta);
    font-weight: 600;
  }

  /* ── Actions Bar ─────────────────────────────────────── */

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .nav-cta {
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
  }

  /* ── Theme Toggle ────────────────────────────────────── */

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition:
      color var(--transition-fast),
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .theme-toggle:hover {
    color: var(--color-cta);
    background: rgba(var(--color-cta-rgb), 0.08);
    border-color: rgba(var(--color-cta-rgb), 0.3);
  }

  /* Light mode: show moon (switch to dark), hide sun */
  .theme-icon--sun {
    display: none;
  }
  .theme-icon--moon {
    display: block;
  }

  /* Dark mode: show sun (switch to light), hide moon */
  :global([data-theme="dark"]) .theme-icon--sun {
    display: block;
  }
  :global([data-theme="dark"]) .theme-icon--moon {
    display: none;
  }

  /* ── Hamburger Toggle ────────────────────────────────── */

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 28px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 0;
    z-index: var(--z-hamburger);
  }

  .toggle-bar {
    --offset: 7px;
    display: block;
    width: 100%;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition:
      transform var(--transition-fast),
      opacity var(--transition-fast);
    transform-origin: center;
  }

  .nav-toggle[aria-expanded="true"] .toggle-bar:nth-child(1) {
    transform: translateY(var(--offset)) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] .toggle-bar:nth-child(3) {
    transform: translateY(calc(-1 * var(--offset))) rotate(-45deg);
  }

  /* ── Mobile Backdrop ─────────────────────────────────── */

  .nav-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--overlay-backdrop);
    z-index: -1;
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .nav-backdrop.visible {
    display: block;
    opacity: 1;
  }

  /* ── Mobile Menu ─────────────────────────────────────── */

  .mobile-menu {
    background: var(--surface-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--border-subtle);
    max-height: 0;
    overflow: hidden;
    transition:
      max-height var(--transition-normal),
      opacity var(--transition-normal);
    opacity: 0;
  }

  .mobile-menu[hidden] {
    display: none;
  }

  .mobile-menu.open {
    max-height: 500px;
    opacity: 1;
  }

  .mobile-links {
    list-style: none;
    padding: 1rem 1.5rem 0;
  }

  .mobile-link {
    display: block;
    padding: 0.875rem 0;
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--border-subtle);
    transition: color var(--transition-fast);
  }

  .mobile-link:hover {
    color: var(--color-cta);
  }

  .mobile-link.active {
    color: var(--color-cta);
    font-weight: 600;
  }

  .mobile-cta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem 1.5rem 2rem;
  }

  .mobile-btn {
    width: 100%;
    justify-content: center;
  }

  /* ── Responsive — Mobile-First ───────────────────────── */

  /* Mobile base: hide desktop nav, show hamburger */
  .nav-links {
    display: none;
  }
  .nav-cta {
    display: none;
  }
  .nav-toggle {
    display: flex;
  }
  .logo-img {
    width: clamp(160px, 50vw, 220px);
  }
  .mobile-menu:not([hidden]) {
    display: block;
  }

  /* Desktop (>=769px): show desktop nav, hide hamburger */
  @media (min-width: 769px) {
    .nav-links {
      display: flex;
    }
    .nav-cta {
      display: inline-flex;
    }
    .nav-toggle {
      display: none;
    }
    .logo-img {
      width: clamp(200px, 30vw, 400px);
    }
    .mobile-menu {
      display: none !important; /* always hidden on desktop regardless of state */
    }
  }
</style>

<script>
  /**
   * Navbar Client Logic — View Transitions Compatible
   *
   * Uses astro:page-load (fires on initial load + every VT navigation)
   * and astro:before-swap for cleanup.
   */

  // ── Module-level state for cleanup ──
  let cleanupFns: Array<() => void> = [];
  let sectionObserver: IntersectionObserver | null = null;

  function initNavbar(): void {
    // ── DOM References ──
    const toggle = document.getElementById(
      "nav-toggle",
    ) as HTMLButtonElement | null;
    const menu = document.getElementById("mobile-menu") as HTMLElement | null;
    const backdrop = document.getElementById(
      "nav-backdrop",
    ) as HTMLElement | null;
    const navbar = document.getElementById("main-nav") as HTMLElement | null;
    const themeBtn = document.getElementById(
      "theme-toggle",
    ) as HTMLButtonElement | null;

    if (!toggle || !menu || !backdrop || !navbar) return;

    // ── Focusable elements selector ──
    const FOCUSABLE =
      'a[href]:not([hidden]), button:not([disabled]):not([hidden]), input:not([hidden]), textarea:not([hidden]), select:not([hidden]), [tabindex]:not([tabindex="-1"]):not([hidden])';

    // ── Menu State ──
    function isMenuOpen(): boolean {
      return toggle!.getAttribute("aria-expanded") === "true";
    }

    function openMenu(): void {
      menu!.removeAttribute("hidden");

      // Force reflow so the transition from max-height:0 → 500px animates
      void menu!.offsetHeight;

      toggle!.setAttribute("aria-expanded", "true");
      toggle!.setAttribute("aria-label", "Menu sluiten");
      menu!.classList.add("open");
      backdrop!.classList.add("visible");
      document.documentElement.style.overflow = "hidden";

      // Move focus to the first focusable element inside the menu
      const firstFocusable = menu!.querySelector<HTMLElement>(FOCUSABLE);
      firstFocusable?.focus();
    }

    function closeMenu(): void {
      toggle!.setAttribute("aria-expanded", "false");
      toggle!.setAttribute("aria-label", "Menu openen");
      menu!.classList.remove("open");
      backdrop!.classList.remove("visible");
      document.documentElement.style.overflow = "";

      // After transition, hide from accessibility tree
      const onTransitionEnd = (): void => {
        if (!isMenuOpen()) {
          menu!.setAttribute("hidden", "");
        }
        menu!.removeEventListener("transitionend", onTransitionEnd);
      };
      menu!.addEventListener("transitionend", onTransitionEnd);
    }

    // ── Focus Trap ──
    function handleFocusTrap(e: KeyboardEvent): void {
      if (e.key !== "Tab" || !isMenuOpen()) return;

      // Collect all focusable elements: hamburger + menu contents
      const focusableEls = [
        toggle!,
        ...Array.from(menu!.querySelectorAll<HTMLElement>(FOCUSABLE)),
      ];
      if (focusableEls.length === 0) return;

      const firstEl = focusableEls[0];
      const lastEl = focusableEls[focusableEls.length - 1];

      if (e.shiftKey) {
        // Shift+Tab: wrap from first → last
        if (document.activeElement === firstEl) {
          e.preventDefault();
          lastEl.focus();
        }
      } else {
        // Tab: wrap from last → first
        if (document.activeElement === lastEl) {
          e.preventDefault();
          firstEl.focus();
        }
      }
    }

    // ── Event: Toggle button click ──
    const onToggleClick = (): void => {
      isMenuOpen() ? closeMenu() : openMenu();
    };
    toggle.addEventListener("click", onToggleClick);
    cleanupFns.push(() => toggle.removeEventListener("click", onToggleClick));

    // ── Event: Mobile link clicks close menu ──
    const mobileLinks = menu.querySelectorAll<HTMLElement>(".mobile-link");
    mobileLinks.forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
    cleanupFns.push(() => {
      mobileLinks.forEach((link) =>
        link.removeEventListener("click", closeMenu),
      );
    });

    // ── Event: Backdrop click closes menu ──
    backdrop.addEventListener("click", closeMenu);
    cleanupFns.push(() => backdrop.removeEventListener("click", closeMenu));

    // ── Event: Escape key closes menu + focus trap ──
    const onKeydown = (e: KeyboardEvent): void => {
      if (e.key === "Escape" && isMenuOpen()) {
        closeMenu();
        toggle!.focus();
        return;
      }
      handleFocusTrap(e);
    };
    document.addEventListener("keydown", onKeydown);
    cleanupFns.push(() => document.removeEventListener("keydown", onKeydown));

    // ── Event: Auto-close on resize past breakpoint ──
    const mql = window.matchMedia("(min-width: 769px)");
    const onMediaChange = (e: MediaQueryListEvent): void => {
      if (e.matches && isMenuOpen()) closeMenu();
    };
    mql.addEventListener("change", onMediaChange);
    cleanupFns.push(() => mql.removeEventListener("change", onMediaChange));

    // ── Scroll Shadow ──
    const onScroll = (): void => {
      navbar.classList.toggle("scrolled", window.scrollY > 20);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    cleanupFns.push(() => window.removeEventListener("scroll", onScroll));

    // Apply initial scroll state
    onScroll();

    // ── Section Highlighting (IntersectionObserver for hash anchors) ──
    const navItems = document.querySelectorAll<HTMLAnchorElement>(
      ".nav-link[href^='#'], .mobile-link[href^='#']",
    );
    const linkMap = new Map<string, HTMLAnchorElement[]>();

    navItems.forEach((link) => {
      const id = link.getAttribute("href")?.replace("#", "") || "";
      if (!linkMap.has(id)) linkMap.set(id, []);
      linkMap.get(id)!.push(link);
    });

    const sections = Array.from(linkMap.keys())
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (sections.length > 0) {
      sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const links = linkMap.get(entry.target.id);
            if (!links) return;
            links.forEach((link) =>
              link.classList.toggle("active", entry.isIntersecting),
            );
          });
        },
        { rootMargin: "-20% 0px -60% 0px", threshold: 0 },
      );
      sections.forEach((s) => sectionObserver!.observe(s));
    }

    // ── Theme Toggle ──
    if (themeBtn) {
      // Set initial aria-label based on current theme
      const html = document.documentElement;
      const setThemeLabel = (): void => {
        const isDark = html.getAttribute("data-theme") === "dark";
        themeBtn!.setAttribute(
          "aria-label",
          isDark ? "Schakel naar licht thema" : "Schakel naar donker thema"
        );
      };
      setThemeLabel();

      const onThemeClick = (): void => {
        const isDark = html.getAttribute("data-theme") === "dark";
        const next = isDark ? "light" : "dark";
        html.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
        setThemeLabel(); // update label after toggling
      };
      themeBtn.addEventListener("click", onThemeClick);
      cleanupFns.push(() =>
        themeBtn.removeEventListener("click", onThemeClick),
      );
    }
  }

  function cleanupNavbar(): void {
    // Remove all registered event listeners
    cleanupFns.forEach((fn) => fn());
    cleanupFns = [];

    // Disconnect IntersectionObserver
    if (sectionObserver) {
      sectionObserver.disconnect();
      sectionObserver = null;
    }
  }

  // ── View Transitions lifecycle ──
  // astro:page-load fires on initial load AND after every VT navigation
  document.addEventListener("astro:page-load", initNavbar);
  // astro:before-swap fires before VT replaces the DOM
  document.addEventListener("astro:before-swap", cleanupNavbar);
</script>
